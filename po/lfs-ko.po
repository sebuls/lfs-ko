"    --disable-nls              \\\n"
"    --enable-shared            \\\n"
"    --enable-gprofng=no        \\\n"
"    --disable-werror           \\\n"
"    --enable-64-bit-bfd        \\\n"
"    --enable-new-dtags         \\\n"
"    --enable-default-hash-style=gnu</userinput>"
