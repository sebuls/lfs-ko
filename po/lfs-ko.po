"usr/include/nfs, /usr/include/protocols, /usr/include/rpc, /usr/include/"
"sys, /usr/lib/audit, /usr/lib/gconv, /usr/lib/locale, /usr/libexec/getconf, /"
"usr/share/i18n, /usr/share/zoneinfo, 및 /var/lib/nss_db"

