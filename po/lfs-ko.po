"            --disable-logger     \\\n"
"            --disable-whois      \\\n"
"            --disable-rcp        \\\n"
"            --disable-rexec      \\\n"
"            --disable-rlogin     \\\n"
"            --disable-rsh        \\\n"
"            --disable-servers</userinput>"
