msgstr "&udev-fin-du;"

#. type: Content of: <sect1><sect2><title>
#: en/chapter08/udev.xml:41
msgid "Installation of Udev"
msgstr "Installation of Udev"

#. type: Content of: <sect1><sect2><para>
#: en/chapter08/udev.xml:43
msgid ""
"Udev is part of the systemd-&systemd-version; package. Use the systemd-"
"&systemd-version;.tar.xz file as the source tarball."
msgstr ""

#. type: Content of: <sect1><sect2><para>
#: en/chapter08/udev.xml:55
msgid "Remove one udev rule requiring a full Systemd installation:"
msgstr "Remove one udev rule requiring a full Systemd installation:"

#. type: Content of: <sect1><sect2><screen>
#: en/chapter08/udev.xml:57
#, no-wrap
msgid "<userinput remap=\"pre\">sed -i '/systemd-sysctl/s/^/#/' rules.d/99-systemd.rules.in</userinput>"
msgstr ""

#. type: Content of: <sect1><sect2><para>
#: en/chapter08/udev.xml:63
msgid ""
"Adjust the hardcoded paths to network configuration files for the standalone "
"udev installation:"
msgstr ""
"Adjust the hardcoded paths to network configuration files for the standalone "
"udev installation:"

#. type: Content of: <sect1><sect2><screen>
#: en/chapter08/udev.xml:66
#, no-wrap
msgid ""
"<userinput remap=\"pre\">sed -e '/NETWORK_DIRS/s/systemd/udev/' \\\n"
"    -i src/libsystemd/sd-network/network-util.h</userinput>"
msgstr ""

#. type: Content of: <sect1><sect2><para>
#: en/chapter08/udev.xml:69
msgid "Prepare Udev for compilation:"
msgstr "Prepare Udev for compilation:"

#. type: Content of: <sect1><sect2><screen>
#: en/chapter08/udev.xml:71
#, no-wrap
msgid ""
"<userinput remap=\"configure\">mkdir -p build\n"
"cd       build\n"
"\n"
"meson setup ..                  \\\n"
"      --prefix=/usr             \\\n"
"      --buildtype=release       \\\n"
"      -D mode=release           \\\n"
"      -D dev-kvm-mode=0660      \\\n"
"      -D link-udev-shared=false \\\n"
"      -D logind=false           \\\n"
"      -D vconsole=false</userinput>"
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><term>
#: en/chapter08/udev.xml:113
msgid "<parameter>-D link-udev-shared=false</parameter>"
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><para>
#: en/chapter08/udev.xml:115
msgid ""
"This option prevents udev from linking to the internal systemd shared "
"library, <systemitem class='library'>libsystemd-shared</systemitem>.  This "
"library is designed to be shared by many Systemd components and it's too "
"overkill for a udev-only installation."
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><term>
#: en/chapter08/udev.xml:124
msgid "<parameter>-D logind=false -D vconsole=false</parameter>"
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><para>
#: en/chapter08/udev.xml:126
msgid ""
"These options prevent the generation of several udev rule files belonging to "
"the other Systemd components that we won't install."
msgstr ""

#. type: Content of: <sect1><sect2><para>
#: en/chapter08/udev.xml:133
msgid ""
"Get the list of the shipped udev helpers and save it into an environment "
"variable (exporting it is not strictly necessary, but it makes building as a "
"regular user or using a package manager easier):"
msgstr ""

#. type: Content of: <sect1><sect2><screen>
#: en/chapter08/udev.xml:137
#, no-wrap
msgid ""
"<userinput remap=\"make\">export udev_helpers=$(grep \"'name' :\" ../src/udev/meson.build | \\\n"
"                      awk '{print $3}' | tr -d \",'\" | grep -v 'udevadm')</userinput>"
msgstr ""

#. type: Content of: <sect1><sect2><para>
#: en/chapter08/udev.xml:140
msgid "Only build the components needed for udev:"
msgstr ""

#. type: Content of: <sect1><sect2><screen>
#: en/chapter08/udev.xml:142
#, no-wrap
msgid ""
"<userinput remap=\"make\">ninja udevadm systemd-hwdb                                           \\\n"
"      $(ninja -n | grep -Eo '(src/(lib)?udev|rules.d|hwdb.d)/[^ ]*') \\\n"
"      $(realpath libudev.so --relative-to .)                         \\\n"
"      $udev_helpers</userinput>"
msgstr ""

#. type: Content of: <sect1><sect2><screen>
#: en/chapter08/udev.xml:149
#, no-wrap
msgid ""
"<userinput remap=\"install\">install -vm755 -d {/usr/lib,/etc}/udev/{hwdb.d,rules.d,network}\n"
"install -vm755 -d /usr/{lib,share}/pkgconfig\n"
"install -vm755 udevadm                             /usr/bin/\n"
"install -vm755 systemd-hwdb                        /usr/bin/udev-hwdb\n"
"ln      -svfn  ../bin/udevadm                      /usr/sbin/udevd\n"
"cp      -av    libudev.so{,*[0-9]}                 /usr/lib/\n"
"install -vm644 ../src/libudev/libudev.h            /usr/include/\n"
"install -vm644 src/libudev/*.pc                    /usr/lib/pkgconfig/\n"
"install -vm644 src/udev/*.pc                       /usr/share/pkgconfig/\n"
"install -vm644 ../src/udev/udev.conf               /etc/udev/\n"
"install -vm644 rules.d/* ../rules.d/README         /usr/lib/udev/rules.d/\n"
"install -vm644 $(find ../rules.d/*.rules \\\n"
"                      -not -name '*power-switch*') /usr/lib/udev/rules.d/\n"
"install -vm644 hwdb.d/*  ../hwdb.d/{*.hwdb,README} /usr/lib/udev/hwdb.d/\n"
"install -vm755 $udev_helpers                       /usr/lib/udev\n"
"install -vm644 ../network/99-default.link          /usr/lib/udev/network</userinput>"
msgstr ""

#. type: Content of: <sect1><sect2><para>
#: en/chapter08/udev.xml:166
msgid ""
"Install some custom rules and support files useful in an LFS environment:"
msgstr ""

#. type: Content of: <sect1><sect2><screen>
#: en/chapter08/udev.xml:169
#, no-wrap
msgid ""
"<userinput remap=\"install\">tar -xvf ../../&udev-lfs-version;.tar.xz\n"
"make -f &udev-lfs-version;/Makefile.lfs install</userinput>"
msgstr ""

#.  Please make sure systemd man pages tarball has a common leading
#.          component in the path.  
#. type: Content of: <sect1><sect2><screen>
#: en/chapter08/udev.xml:176
#, no-wrap
msgid ""
"<userinput remap=\"install\">tar -xf ../../systemd-man-pages-&systemd-man-version;.tar.xz                          \\\n"
"    --no-same-owner --strip-components=1                              \\\n"
"    -C /usr/share/man --wildcards '*/udev*' '*/libudev*'              \\\n"
"                                  '*/systemd.link.5'                  \\\n"
"                                  '*/systemd-'{hwdb,udevd.service}.8\n"
"\n"
"sed 's|systemd/network|udev/network|'                                 \\\n"
"    /usr/share/man/man5/systemd.link.5                                \\\n"
"  > /usr/share/man/man5/udev.link.5\n"
"\n"
"sed 's/systemd\\(\\\\\\?-\\)/udev\\1/' /usr/share/man/man8/systemd-hwdb.8   \\\n"
"                               > /usr/share/man/man8/udev-hwdb.8\n"
"\n"
"sed 's|lib.*udevd|sbin/udevd|'                                        \\\n"
"    /usr/share/man/man8/systemd-udevd.service.8                       \\\n"
"  > /usr/share/man/man8/udevd.8\n"
"\n"
"rm /usr/share/man/man*/systemd*</userinput>"
msgstr ""

#. type: Content of: <sect1><sect2><para>
#: en/chapter08/udev.xml:195
msgid "Finally, unset the <envar>udev_helpers</envar> variable:"
msgstr ""

#.  remap="make" seems confusing but we don't have sth. like
#.          remap="clean".  
#. type: Content of: <sect1><sect2><screen>
#: en/chapter08/udev.xml:199
#, no-wrap
msgid "<userinput remap=\"install\">unset udev_helpers</userinput>"
msgstr ""

