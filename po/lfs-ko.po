#. type: Content of: <sect1><sect2><para>
#: en/chapter08/systemd.xml:43 en/chapter08/udev.xml:46
msgid ""
"Remove two unneeded groups, <systemitem class=\"groupname\">render</"
"systemitem> and <systemitem class=\"groupname\">sgx</systemitem>, from the "
"default udev rules:"
msgstr ""
"Remove two unneeded groups, <systemitem class=\"groupname\">render</"
"systemitem> and <systemitem class=\"groupname\">sgx</systemitem>, from the "
"default udev rules:"

#. type: Content of: <sect1><sect2><screen>
#: en/chapter08/systemd.xml:48 en/chapter08/udev.xml:51
#, no-wrap
msgid ""
"<userinput remap=\"pre\">sed -e 's/GROUP=\"render\"/GROUP=\"video\"/' \\\n"
"    -e 's/GROUP=\"sgx\", //'               \\\n"
"    -i rules.d/50-udev-default.rules.in</userinput>"
msgstr ""

#. type: Content of: <sect1><sect2><para>
#: en/chapter08/systemd.xml:52
msgid "Prepare systemd for compilation:"
msgstr "Prepare systemd for compilation:"

#. type: Content of: <sect1><sect2><screen>
#: en/chapter08/systemd.xml:54
#, no-wrap
msgid ""
"<userinput remap=\"configure\">mkdir -p build\n"
"cd       build\n"
"\n"
"meson setup ..                \\\n"
"      --prefix=/usr           \\\n"
"      --buildtype=release     \\\n"
"      -D default-dnssec=no    \\\n"
"      -D firstboot=false      \\\n"
"      -D install-tests=false  \\\n"
"      -D ldconfig=false       \\\n"
"      -D sysusers=false       \\\n"
"      -D rpmmacrosdir=no      \\\n"
"      -D homed=disabled       \\\n"
"      -D man=disabled         \\\n"
"      -D mode=release         \\\n"
"      -D pamconfdir=no        \\\n"
"      -D dev-kvm-mode=0660    \\\n"
"      -D nobody-group=nogroup \\\n"
"      -D sysupdate=disabled   \\\n"
"      -D ukify=disabled       \\\n"
"      -D docdir=/usr/share/doc/systemd-&systemd-version;</userinput>"
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><term>
#: en/chapter08/systemd.xml:80 en/chapter08/udev.xml:87
msgid "<parameter>--buildtype=release</parameter>"
msgstr "<parameter>--buildtype=release</parameter>"

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><para>
#: en/chapter08/systemd.xml:82 en/chapter08/udev.xml:89
msgid ""
"This switch overrides the default buildtype (<quote>debug</quote>), which "
"produces unoptimized binaries."
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><term>
#: en/chapter08/systemd.xml:89
msgid "<parameter>-D default-dnssec=no</parameter>"
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><para>
#: en/chapter08/systemd.xml:91
msgid "This switch turns off the experimental DNSSEC support."
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><term>
#: en/chapter08/systemd.xml:96
msgid "<parameter>-D firstboot=false</parameter>"
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><para>
#: en/chapter08/systemd.xml:98
msgid ""
"This switch prevents installation of systemd services responsible for "
"setting up the system for the first time. These are not useful in LFS, "
"because everything is done manually."
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><term>
#: en/chapter08/systemd.xml:106
msgid "<parameter>-D install-tests=false</parameter>"
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><para>
#: en/chapter08/systemd.xml:108
msgid "This switch prevents installation of the compiled tests."
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><term>
#: en/chapter08/systemd.xml:113
msgid "<parameter>-D ldconfig=false</parameter>"
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><para>
#: en/chapter08/systemd.xml:115
msgid ""
"This switch prevents installation of a systemd unit that runs "
"<command>ldconfig</command> at boot; this is not useful for source "
"distributions such as LFS, and makes the boot time longer. Remove this "
"option to enable running <command>ldconfig</command> at boot."
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><term>
#: en/chapter08/systemd.xml:123
msgid "<parameter>-D sysusers=false</parameter>"
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><para>
#: en/chapter08/systemd.xml:125
msgid ""
"This switch prevents installation of systemd services responsible for "
"setting up the <filename>/etc/group</filename> and <filename>/etc/passwd</"
"filename> files. Both files were created in the previous chapter. This "
"daemon is not useful on an LFS system since user accounts are manually "
"created."
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><term>
#: en/chapter08/systemd.xml:135
msgid "<parameter>-D rpmmacrosdir=no</parameter>"
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><para>
#: en/chapter08/systemd.xml:137
msgid ""
"This switch disables installation of RPM Macros for use with systemd, "
"because LFS does not support RPM."
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><term>
#: en/chapter08/systemd.xml:143
msgid "<parameter>-D homed=disabled</parameter>"
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><para>
#: en/chapter08/systemd.xml:145
msgid ""
"Remove a daemon which has dependencies that do not fit within the scope of "
"LFS."
msgstr ""
"Remove a daemon which has dependencies that do not fit within the scope of "
"LFS."

#. type: Content of: <sect1><sect2><variablelist><varlistentry><term>
#: en/chapter08/systemd.xml:151
msgid "<parameter>-D man=disabled</parameter>"
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><para>
#: en/chapter08/systemd.xml:153
msgid ""
"Prevent the generation of man pages to avoid extra dependencies.  We will "
"install pre-generated man pages for systemd from a tarball."
msgstr ""
"Prevent the generation of man pages to avoid extra dependencies.  We will "
"install pre-generated man pages for systemd from a tarball."

#. type: Content of: <sect1><sect2><variablelist><varlistentry><term>
#: en/chapter08/systemd.xml:160 en/chapter08/udev.xml:96
msgid "<parameter>-D mode=release</parameter>"
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><para>
#: en/chapter08/systemd.xml:162 en/chapter08/udev.xml:98
msgid "Disable some features considered experimental by upstream."
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><term>
#: en/chapter08/systemd.xml:168
msgid "<parameter>-D pamconfdir=no</parameter>"
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><para>
#: en/chapter08/systemd.xml:170
msgid ""
"Prevent the installation of a PAM configuration file not functional on LFS."
msgstr ""
"Prevent the installation of a PAM configuration file not functional on LFS."

#. type: Content of: <sect1><sect2><variablelist><varlistentry><term>
#: en/chapter08/systemd.xml:176 en/chapter08/udev.xml:104
msgid "<parameter>-D dev-kvm-mode=0660</parameter>"
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><para>
#: en/chapter08/systemd.xml:178 en/chapter08/udev.xml:106
msgid ""
"The default udev rule would allow all users to access <filename "
"class='devicefile'>/dev/kvm</filename>.  The editors consider it dangerous.  "
"This option overrides it."
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><term>
#: en/chapter08/systemd.xml:185
msgid "<parameter>-D nobody-group=nogroup</parameter>"
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><para>
#: en/chapter08/systemd.xml:187
msgid ""
"Tell the package the group name with GID 65534 is <systemitem "
"class='groupname'>nogroup</systemitem>."
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><term>
#: en/chapter08/systemd.xml:193
msgid "<parameter>-D sysupdate=disabled</parameter>"
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><para>
#: en/chapter08/systemd.xml:195
msgid ""
"Do not install the <command>systemd-sysupdate</command> tool.  It's designed "
"for automatically upgrading binary distros, so it's useless for a basic "
"Linux system built from source.  And it will report errors on boot if it's "
"enabled but not properly configured."
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><term>
#: en/chapter08/systemd.xml:204
msgid "<parameter>-D ukify=disabled</parameter>"
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><para>
#: en/chapter08/systemd.xml:206
msgid ""
"Do not install the <command>systemd-ukify</command> script.  At runtime this "
"script requires the <application>pefile</application> Python module that "
"neither LFS nor BLFS provides."
msgstr ""

#. type: Content of: <sect1><sect2><para>
#: en/chapter08/systemd.xml:219
msgid ""
"One test creates a mount point in <filename class='directory'>/tmp</"
"filename> that we cannot clean up so easily after running the test suite, "
"and some tests need a basic <filename>/etc/os-release</filename> file.  To "
"test the results, create this file and run the test suite in a separate "
"mount namespace (so the mount point is only visible for the test suite and "
"it gets cleaned up automatically after the test suite finishes):"
msgstr ""

#. type: Content of: <sect1><sect2><screen>
#: en/chapter08/systemd.xml:227
#, no-wrap
msgid ""
"<userinput remap=\"test\">echo 'NAME=\"Linux From Scratch\"' &gt; /etc/os-release\n"
"unshare -m ninja test</userinput>"
msgstr ""

#. type: Content of: <sect1><sect2><para>
#: en/chapter08/systemd.xml:232
msgid ""
"One test named <literal>systemd:core / test-namespace</literal> is known to "
"fail in the LFS chroot environment.  Some other tests may fail because they "
"depend on various kernel configuration options.  The test named "
"<literal>systemd:test / test-copy</literal> may time out due to an I/O "
"congestion with a large parallel job number, but it would pass if running "
"alone with <command>meson test test-copy</command>."
msgstr ""

#. type: Content of: <sect1><sect2><para>
#: en/chapter08/systemd.xml:244 en/chapter08/udev.xml:172
msgid "Install the man pages:"
msgstr ""

#.  Please make sure systemd man pages tarball has a common leading
#.          component in the path.  
#. type: Content of: <sect1><sect2><screen>
#: en/chapter08/systemd.xml:248
#, no-wrap
msgid ""
"<userinput remap=\"install\">tar -xf ../../systemd-man-pages-&systemd-man-version;.tar.xz \\\n"
"    --no-same-owner --strip-components=1     \\\n"
"    -C /usr/share/man</userinput>"
msgstr ""

#. type: Content of: <sect1><sect2><para>
#: en/chapter08/systemd.xml:252
msgid ""
"Create the <filename>/etc/machine-id</filename> file needed by "
"<command>systemd-journald</command>:"
msgstr ""

#. type: Content of: <sect1><sect2><screen>
#: en/chapter08/systemd.xml:255
#, no-wrap
msgid "<userinput remap=\"adjust\">systemd-machine-id-setup</userinput>"
msgstr ""

#. type: Content of: <sect1><sect2><para>
#: en/chapter08/systemd.xml:257
msgid "Set up the basic target structure:"
msgstr ""

#. type: Content of: <sect1><sect2><screen>
#: en/chapter08/systemd.xml:259
#, no-wrap
msgid "<userinput remap=\"adjust\">systemctl preset-all</userinput>"
msgstr ""

#. type: Content of: <sect1><sect2><title>
#: en/chapter08/systemd.xml:273
msgid "Contents of systemd"
msgstr ""

#. type: Content of: <sect1><sect2><segmentedlist><seglistitem><seg>
#: en/chapter08/systemd.xml:281
msgid ""
"bootctl, busctl, coredumpctl, halt (symlink to systemctl), hostnamectl, "
"init, journalctl, kernel-install, localectl, loginctl, machinectl, mount.ddi "
"(symlink to systemd-dissect), networkctl, oomctl, portablectl, poweroff "
"(symlink to systemctl), reboot (symlink to systemctl), resolvconf (symlink "
"to resolvectl), resolvectl, run0 (symlink to systemd-run), runlevel (symlink "
"to systemctl), shutdown (symlink to systemctl), systemctl, systemd-ac-power, "
"systemd-analyze, systemd-ask-password, systemd-cat, systemd-cgls, systemd-"
"cgtop, systemd-confext (symlink to systemd-sysext), systemd-creds, systemd-"
"delta, systemd-detect-virt, systemd-dissect, systemd-escape, systemd-hwdb, "
"systemd-id128, systemd-inhibit, systemd-machine-id-setup, systemd-mount, "
"systemd-notify, systemd-nspawn, systemd-path, systemd-pty-forward, systemd-"
"repart, systemd-resolve (symlink to resolvectl), systemd-run, systemd-socket-"
"activate, systemd-stdio-bridge, systemd-sysext, systemd-tmpfiles, systemd-"
"tty-ask-password-agent, systemd-vpick, systemd-umount (symlink to systemd-"
"mount), timedatectl, udevadm, userdbctl, and varlinkctl"
msgstr ""

#. type: Content of: <sect1><sect2><segmentedlist><seglistitem><seg>
#: en/chapter08/systemd.xml:301
msgid ""
"libnss_myhostname.so.2, libnss_mymachines.so.2, libnss_resolve.so.2, "
"libnss_systemd.so.2, libsystemd.so, libsystemd-shared-&systemd-version;.so "
"(in /usr/lib/systemd), and libudev.so"
msgstr ""
"libnss_myhostname.so.2, libnss_mymachines.so.2, libnss_resolve.so.2, "
"libnss_systemd.so.2, libsystemd.so, libsystemd-shared-&systemd-version;.so "
"(in /usr/lib/systemd), and libudev.so"

#. type: Content of: <sect1><sect2><segmentedlist><seglistitem><seg>
#: en/chapter08/systemd.xml:305
msgid ""
"/etc/binfmt.d, /etc/init.d, /etc/kernel, /etc/modules-load.d, /etc/"
"sysctl.d, /etc/systemd, /etc/tmpfiles.d, /etc/udev, /etc/xdg/systemd, /usr/"
"include/systemd, /usr/lib/binfmt.d, /usr/lib/credstore, /usr/lib/"
"environment.d, /usr/lib/kernel, /usr/lib/modprobe.d, /usr/lib/modules-"
"load.d, /usr/lib/systemd, /usr/lib/udev, /usr/lib/sysctl.d, /usr/lib/"
"systemd, /usr/lib/tmpfiles.d, /usr/share/doc/systemd-&systemd-version;, /usr/"
"share/factory, /usr/share/systemd, /var/lib/systemd, and /var/log/journal"
msgstr ""
"/etc/binfmt.d, /etc/init.d, /etc/kernel, /etc/modules-load.d, /etc/"
"sysctl.d, /etc/systemd, /etc/tmpfiles.d, /etc/udev, /etc/xdg/systemd, /usr/"
"include/systemd, /usr/lib/binfmt.d, /usr/lib/credstore, /usr/lib/"
"environment.d, /usr/lib/kernel, /usr/lib/modprobe.d, /usr/lib/modules-"
"load.d, /usr/lib/systemd, /usr/lib/udev, /usr/lib/sysctl.d, /usr/lib/"
