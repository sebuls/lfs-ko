#. type: Content of: <sect1><sect2><para>
#: en/chapter08/pkgconf.xml:47
msgid "Prepare Pkgconf for compilation:"
msgstr "Pkgconf 컴파일 준비하기:"

#. type: Content of: <sect1><sect2><screen>
#: en/chapter08/pkgconf.xml:49
#, no-wrap
msgid ""
"<userinput remap=\"configure\">./configure --prefix=/usr    \\\n"
"            --disable-static \\\n"
"            --docdir=/usr/share/doc/pkgconf-&pkgconf-version;</userinput>"
msgstr ""
"<userinput remap=\"configure\">./configure --prefix=/usr    \\\n"
"            --disable-static \\\n"
"            --docdir=/usr/share/doc/pkgconf-&pkgconf-version;</userinput>"

#. type: Content of: <sect1><sect2><para>
#: en/chapter08/pkgconf.xml:61
msgid ""
"To maintain compatibility with the original Pkg-config create two symlinks:"
msgstr ""

#. type: Content of: <sect1><sect2><screen>
#: en/chapter08/pkgconf.xml:64
#, no-wrap
msgid ""
"<userinput remap=\"install\">ln -sv pkgconf   /usr/bin/pkg-config\n"
"ln -sv pkgconf.1 /usr/share/man/man1/pkg-config.1</userinput>"
msgstr ""
"<userinput remap=\"install\">ln -sv pkgconf   /usr/bin/pkg-config\n"
"ln -sv pkgconf.1 /usr/share/man/man1/pkg-config.1</userinput>"

