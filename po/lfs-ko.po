msgstr "free"

#. type: Content of: <sect1><sect2><variablelist><varlistentry><term>
#: en/chapter08/procps.xml:135
msgid "<command>pgrep</command>"
msgstr "<command>pgrep</command>"

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><para>
#: en/chapter08/procps.xml:137
msgid "Looks up processes based on their name and other attributes"
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><indexterm><primary>
#: en/chapter08/procps.xml:139
msgid "pgrep"
msgstr "pgrep"

#. type: Content of: <sect1><sect2><variablelist><varlistentry><term>
#: en/chapter08/procps.xml:145
msgid "<command>pidof</command>"
