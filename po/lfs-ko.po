#: en/chapter08/packaging.xml:46
msgid "Installation of Packaging"
msgstr "Packaging 설치"

#. type: Content of: <sect1><sect2><para>
#: en/chapter08/packaging.xml:48
msgid "Compile packaging with the following command:"
msgstr "다음 명령어로 packaging을 컴파일:"

#. type: Content of: <sect1><sect2><para>
#: en/chapter08/packaging.xml:52
msgid "Install packaging with the following command:"
msgstr "아래 명령으로 패키지 설치:"

#. type: Content of: <sect1><sect2><screen>
#: en/chapter08/packaging.xml:54
#, no-wrap
msgid "<userinput remap=\"install\">pip3 install --no-index --find-links dist packaging</userinput>"
msgstr "<userinput remap=\"install\">pip3 install --no-index --find-links dist packaging</userinput>"

