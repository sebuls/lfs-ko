"            --runstatedir=/run    \\\n"
"            --disable-chfn-chsh   \\\n"
"            --disable-login       \\\n"
"            --disable-nologin     \\\n"
"            --disable-su          \\\n"
"            --disable-setpriv     \\\n"
"            --disable-runuser     \\\n"
"            --disable-pylibmount  \\\n"
"            --disable-static      \\\n"
"            --disable-liblastlog2 \\\n"
"            --without-python      \\\n"
"            ADJTIME_PATH=/var/lib/hwclock/adjtime \\\n"
"            --docdir=/usr/share/doc/util-linux-&util-linux-version;</userinput>"
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><term>
#: en/chapter07/util-linux.xml:73
