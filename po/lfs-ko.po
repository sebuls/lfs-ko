"            --enable-pcre2-16                   \\\n"
"            --enable-pcre2-32                   \\\n"
"            --enable-pcre2grep-libz             \\\n"
"            --enable-pcre2grep-libbz2           \\\n"
"            --enable-pcre2test-libreadline      \\\n"
"            --disable-static</userinput>"

