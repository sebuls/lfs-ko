#. type: Attribute 'xreflabel' of: <chapter>
#: en/chapter08/chapter08.xml:8
msgid "Chapter&nbsp;8"
msgstr "제8장"

#. type: Content of: <chapter><title>
#: en/chapter08/chapter08.xml:12
msgid "Installing Basic System Software"
msgstr "기본 시스템 소프트웨어 설치"

#. type: Content of: <sect1><title>
#: en/chapter08/cleanup.xml:11
msgid "Cleaning Up"
msgstr ""

#. type: Content of: <sect1><para>
#: en/chapter08/cleanup.xml:13
msgid "Finally, clean up some extra files left over from running tests:"
msgstr ""

#. type: Content of: <sect1><screen>
#: en/chapter08/cleanup.xml:15
#, no-wrap
msgid "<userinput>rm -rf /tmp/{*,.*}</userinput>"
msgstr ""

#. type: Content of: <sect1><para>
#: en/chapter08/cleanup.xml:17
msgid ""
"There are also several files in the /usr/lib and /usr/libexec directories "
"with a file name extension of .la. These are \"libtool archive\" files. On a "
"modern Linux system the libtool .la files are only useful for libltdl.  No "
"libraries in LFS are expected to be loaded by libltdl, and it's known that "
"some .la files can break BLFS package builds.  Remove those files now:"
msgstr ""

#. type: Content of: <sect1><screen>
#: en/chapter08/cleanup.xml:24
#, no-wrap
msgid "<userinput>find /usr/lib /usr/libexec -name \\*.la -delete</userinput>"
msgstr ""

#. type: Content of: <sect1><para>
#: en/chapter08/cleanup.xml:26
msgid ""
"For more information about libtool archive files, see the <ulink url=\"&blfs-"
"book;introduction/la-files.html\">BLFS section \"About Libtool Archive (.la) "
"files\"</ulink>."
msgstr ""

#. type: Content of: <sect1><para>
#: en/chapter08/cleanup.xml:30
msgid ""
"The compiler built in <xref linkend=\"chapter-temporary-tools\"/> and <xref "
"linkend=\"chapter-chroot-temporary-tools\"/> is still partially installed "
"and not needed anymore. Remove it with:"
msgstr ""

#. type: Content of: <sect1><screen>
#: en/chapter08/cleanup.xml:34
#, no-wrap
msgid "<userinput>find /usr -depth -name $(uname -m)-lfs-linux-gnu\\* | xargs rm -rf</userinput>"
msgstr ""

#. type: Content of: <sect1><para>
#: en/chapter08/cleanup.xml:36
msgid ""
"Finally, remove the temporary 'tester' user account created at the beginning "
"of the previous chapter."
msgstr ""

#. type: Content of: <sect1><screen>
#: en/chapter08/cleanup.xml:39
#, no-wrap
msgid "<userinput>userdel -r tester</userinput>"
msgstr ""

#. type: Content of: <sect1><sect2><para>
#: en/chapter08/coreutils.xml:26
msgid ""
"The Coreutils package contains the basic utility programs needed by every "
"operating system."
msgstr ""

#. type: Content of: <sect1><sect2><segmentedlist><seglistitem><seg>
#: en/chapter08/coreutils.xml:34
msgid "&coreutils-fin-sbu;"
msgstr ""

#. type: Content of: <sect1><sect2><segmentedlist><seglistitem><seg>
#: en/chapter08/coreutils.xml:35
msgid "&coreutils-fin-du;"
msgstr ""

#. type: Content of: <sect1><sect2><para>
#: en/chapter08/coreutils.xml:44
msgid ""
"POSIX requires that programs from Coreutils recognize character boundaries "
"correctly even in multibyte locales. The following patch fixes this non-"
"compliance and other internationalization-related bugs."
msgstr ""

#. type: Content of: <sect1><sect2><screen>
#: en/chapter08/coreutils.xml:48
#, no-wrap
msgid "<userinput remap=\"pre\">patch -Np1 -i ../&coreutils-i18n-patch;</userinput>"
msgstr ""

#. type: Content of: <sect1><sect2><note><para>
#: en/chapter08/coreutils.xml:51
msgid ""
"Many bugs have been found in this patch. When reporting new bugs to the "
"Coreutils maintainers, please check first to see if those bugs are "
"reproducible without this patch."
msgstr ""

#. type: Content of: <sect1><sect2><para>
#: en/chapter08/coreutils.xml:65
msgid "Now prepare Coreutils for compilation:"
msgstr ""

#. type: Content of: <sect1><sect2><screen>
#: en/chapter08/coreutils.xml:67
#, no-wrap
msgid ""
"<userinput remap=\"configure\">autoreconf -fv\n"
"automake -af\n"
"FORCE_UNSAFE_CONFIGURE=1 ./configure \\\n"
"            --prefix=/usr</userinput>"
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><title>
#: en/chapter08/coreutils.xml:73
msgid "The meaning of the commands and configure options:"
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><term>
#: en/chapter08/coreutils.xml:76
msgid "<command>autoreconf -fv</command>"
msgstr "<command>autoreconf -fv</command>"

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><para>
#: en/chapter08/coreutils.xml:78
msgid ""
"The patch for internationalization has modified the build system, so the "
"configuration files must be regenerated.  Normally we would use the "
"<parameter>-i</parameter> option to update the standard auxiliary files, but "
"for this package it does not work because <filename>configure.ac</filename> "
"specified an old gettext version."
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><term>
#: en/chapter08/coreutils.xml:89
msgid "<command>automake -af</command>"
msgstr "<command>automake -af</command>"

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><para>
#: en/chapter08/coreutils.xml:91
msgid ""
"The automake auxiliary files were not updated by <command>autoreconf</"
"command> due to the missing <parameter>-i</parameter> option.  This command "
"updates them to prevent a build failure."
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><term>
#: en/chapter08/coreutils.xml:99 en/chapter08/tar.xml:55
msgid "<envar>FORCE_UNSAFE_CONFIGURE=1</envar>"
msgstr "<envar>FORCE_UNSAFE_CONFIGURE=1</envar>"

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><para>
#: en/chapter08/coreutils.xml:101
msgid ""
"This environment variable allows the package to be built by the <systemitem "
"class=\"username\">root</systemitem> user."
msgstr ""

#. type: Content of: <sect1><sect2><para>
#: en/chapter08/coreutils.xml:125
msgid ""
"Now the test suite is ready to be run. First, run the tests that are meant "
"to be run as user <systemitem class=\"username\">root</systemitem>:"
msgstr ""

#. type: Content of: <sect1><sect2><screen>
#: en/chapter08/coreutils.xml:128
#, no-wrap
msgid "<userinput remap=\"test\">make NON_ROOT_USERNAME=tester check-root</userinput>"
msgstr ""

#. type: Content of: <sect1><sect2><para>
#: en/chapter08/coreutils.xml:130
msgid ""
"We're going to run the remainder of the tests as the <systemitem "
"class=\"username\">tester</systemitem> user. Certain tests require that the "
"user be a member of more than one group. So that these tests are not "
"skipped, add a temporary group and make the user <systemitem "
"class=\"username\">tester</systemitem> a part of it:"
msgstr ""

#. type: Content of: <sect1><sect2><screen>
#: en/chapter08/coreutils.xml:136
#, no-wrap
msgid "<userinput remap=\"test\">groupadd -g 102 dummy -U tester</userinput>"
msgstr ""

#. type: Content of: <sect1><sect2><para>
#: en/chapter08/coreutils.xml:138
msgid ""
"Fix some of the permissions so that the non-&root; user can compile and run "
"the tests:"
msgstr ""

#. type: Content of: <sect1><sect2><screen>
#: en/chapter08/coreutils.xml:141
#, no-wrap
msgid "<userinput remap=\"test\">chown -R tester . </userinput>"
msgstr ""

#. type: Content of: <sect1><sect2><para>
#: en/chapter08/coreutils.xml:147
msgid ""
"Now run the tests (using <filename>/dev/null</filename> for the standard "
"input, or two tests may be broken if building LFS in a graphical terminal or "
"a session in SSH or GNU Screen because the standard input is connected to a "
"PTY from host distro, and the device node for such a PTY cannot be accessed "
"from the LFS chroot environment):"
msgstr ""

#. type: Content of: <sect1><sect2><screen>
#: en/chapter08/coreutils.xml:154
#, no-wrap
msgid ""
"<userinput remap=\"test\">su tester -c \"PATH=$PATH make -k RUN_EXPENSIVE_TESTS=yes check\" \\\n"
"   &lt; /dev/null</userinput>"
msgstr ""

#. type: Content of: <sect1><sect2><para>
#: en/chapter08/coreutils.xml:157
msgid "Remove the temporary group:"
msgstr "Remove the temporary group:"

#. type: Content of: <sect1><sect2><screen>
#: en/chapter08/coreutils.xml:159
#, no-wrap
msgid "<userinput remap=\"test\">groupdel dummy</userinput>"
msgstr ""

#. type: Content of: <sect1><sect2><para>
#: en/chapter08/coreutils.xml:165
msgid "Move programs to the locations specified by the FHS:"
msgstr ""

#. type: Content of: <sect1><sect2><screen>
#: en/chapter08/coreutils.xml:167
#, no-wrap
msgid ""
"<userinput remap=\"install\">mv -v /usr/bin/chroot /usr/sbin\n"
"mv -v /usr/share/man/man1/chroot.1 /usr/share/man/man8/chroot.8\n"
"sed -i 's/\"1\"/\"8\"/' /usr/share/man/man8/chroot.8</userinput>"
msgstr ""

#. type: Content of: <sect1><sect2><title>
#: en/chapter08/coreutils.xml:174
msgid "Contents of Coreutils"
msgstr ""

#. type: Content of: <sect1><sect2><segmentedlist><seglistitem><seg>
#: en/chapter08/coreutils.xml:182
msgid ""
"[, b2sum, base32, base64, basename, basenc, cat, chcon, chgrp, chmod, chown, "
"chroot, cksum, comm, cp, csplit, cut, date, dd, df, dir, dircolors, dirname, "
"du, echo, env, expand, expr, factor, false, fmt, fold, groups, head, hostid, "
"id, install, join, link, ln, logname, ls, md5sum, mkdir, mkfifo, mknod, "
"mktemp, mv, nice, nl, nohup, nproc, numfmt, od, paste, pathchk, pinky, pr, "
"printenv, printf, ptx, pwd, readlink, realpath, rm, rmdir, runcon, seq, "
"sha1sum, sha224sum, sha256sum, sha384sum, sha512sum, shred, shuf, sleep, "
"sort, split, stat, stdbuf, stty, sum, sync, tac, tail, tee, test, timeout, "
"touch, tr, true, truncate, tsort, tty, uname, unexpand, uniq, unlink, users, "
"vdir, wc, who, whoami, and yes"
msgstr ""

#. type: Content of: <sect1><sect2><segmentedlist><seglistitem><seg>
#: en/chapter08/coreutils.xml:193
msgid "libstdbuf.so (in /usr/libexec/coreutils)"
msgstr "libstdbuf.so (in /usr/libexec/coreutils)"

#. type: Content of: <sect1><sect2><segmentedlist><seglistitem><seg>
#: en/chapter08/coreutils.xml:194
msgid "/usr/libexec/coreutils"
msgstr "/usr/libexec/coreutils"

#. type: Content of: <sect1><sect2><variablelist><varlistentry><term>
#: en/chapter08/coreutils.xml:204
msgid "<command>[</command>"
msgstr "<command>[</command>"

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><para>
#: en/chapter08/coreutils.xml:206
msgid ""
"Is an actual command, /usr/bin/[; it is a synonym for the <command>test</"
"command> command"
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><indexterm><primary>
#: en/chapter08/coreutils.xml:209
msgid "["
msgstr "["

#. type: Content of: <sect1><sect2><variablelist><varlistentry><term>
#: en/chapter08/coreutils.xml:215
msgid "<command>base32</command>"
msgstr "<command>base32</command>"

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><para>
#: en/chapter08/coreutils.xml:217
msgid ""
"Encodes and decodes data according to the base32 specification (RFC 4648)"
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><indexterm><primary>
#: en/chapter08/coreutils.xml:220 en/chapter08/coreutils.xml:231
msgid "base64"
msgstr "base64"

#. type: Content of: <sect1><sect2><variablelist><varlistentry><term>
#: en/chapter08/coreutils.xml:226
msgid "<command>base64</command>"
msgstr "<command>base64</command>"

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><para>
