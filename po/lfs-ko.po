#. type: Content of: <sect1><sect2><title>
#: en/chapter08/tcl.xml:45
msgid "Installation of Tcl"
msgstr "Installation of Tcl"

#. type: Content of: <sect1><sect2><para>
#: en/chapter08/tcl.xml:47
msgid ""
"This package and the next two (Expect and DejaGNU) are installed to support "
"running the test suites for Binutils, GCC and other packages.  Installing "
"three packages for testing purposes may seem excessive, but it is very "
"reassuring, if not essential, to know that the most important tools are "
"working properly."
msgstr ""

#. type: Content of: <sect1><sect2><para>
#: en/chapter08/tcl.xml:53
msgid "Prepare Tcl for compilation:"
msgstr "Prepare Tcl for compilation:"

#. type: Content of: <sect1><sect2><screen>
#: en/chapter08/tcl.xml:55
#, no-wrap
msgid ""
"<userinput remap=\"configure\">SRCDIR=$(pwd)\n"
"cd unix\n"
"./configure --prefix=/usr           \\\n"
"            --mandir=/usr/share/man \\\n"
"            --disable-rpath</userinput>"
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><term>
#: en/chapter08/tcl.xml:65
msgid "<parameter>--disable-rpath</parameter>"
msgstr "<parameter>--disable-rpath</parameter>"

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><para>
#: en/chapter08/tcl.xml:67
msgid ""
"This parameter prevents hard coding library search paths (rpath) into the "
"binary executable files and shared libraries.  This package does not need "
"rpath for an installation into the standard location, and rpath may "
"sometimes cause unwanted effects or even security issues."
msgstr ""

#. type: Content of: <sect1><sect2><screen>
#: en/chapter08/tcl.xml:78
#, no-wrap
msgid ""
"<userinput remap=\"make\">make\n"
"\n"
"sed -e \"s|$SRCDIR/unix|/usr/lib|\" \\\n"
"    -e \"s|$SRCDIR|/usr/include|\"  \\\n"
"    -i tclConfig.sh\n"
"\n"
"sed -e \"s|$SRCDIR/unix/pkgs/tdbc&tdbc-ver;|/usr/lib/tdbc&tdbc-ver;|\" \\\n"
"    -e \"s|$SRCDIR/pkgs/tdbc&tdbc-ver;/generic|/usr/include|\"     \\\n"
"    -e \"s|$SRCDIR/pkgs/tdbc&tdbc-ver;/library|/usr/lib/tcl8.6|\"  \\\n"
"    -e \"s|$SRCDIR/pkgs/tdbc&tdbc-ver;|/usr/include|\"             \\\n"
"    -i pkgs/tdbc&tdbc-ver;/tdbcConfig.sh\n"
"\n"
"sed -e \"s|$SRCDIR/unix/pkgs/itcl&itcl-ver;|/usr/lib/itcl&itcl-ver;|\" \\\n"
"    -e \"s|$SRCDIR/pkgs/itcl&itcl-ver;/generic|/usr/include|\"    \\\n"
"    -e \"s|$SRCDIR/pkgs/itcl&itcl-ver;|/usr/include|\"            \\\n"
"    -i pkgs/itcl&itcl-ver;/itclConfig.sh\n"
"\n"
"unset SRCDIR</userinput>"
msgstr ""

#. type: Content of: <sect1><sect2><para>
#: en/chapter08/tcl.xml:97
msgid ""
"The various <quote>sed</quote> instructions after the <quote>make</quote> "
"command remove references to the build directory from the configuration "
"files and replace them with the install directory.  This is not mandatory "
"for the remainder of LFS, but may be needed if a package built later uses "
"Tcl."
msgstr ""

#. type: Content of: <sect1><sect2><screen>
#: en/chapter08/tcl.xml:105
#, no-wrap
msgid "<userinput remap=\"test\">LC_ALL=C.UTF-8 make test</userinput>"
msgstr ""

#. type: Content of: <sect1><sect2><screen>
#: en/chapter08/tcl.xml:109
#, no-wrap
msgid ""
"<userinput remap=\"install\">make install \n"
"chmod 644 /usr/lib/libtclstub&tcl-major-version;.a</userinput>"
msgstr ""

#. type: Content of: <sect1><sect2><para>
#: en/chapter08/tcl.xml:112
msgid ""
"Make the installed library writable so debugging symbols can be removed "
"later:"
msgstr ""
"Make the installed library writable so debugging symbols can be removed "
"later:"

#. type: Content of: <sect1><sect2><screen>
#: en/chapter08/tcl.xml:115
#, no-wrap
msgid "<userinput remap=\"install\">chmod -v u+w /usr/lib/libtcl&tcl-major-version;.so</userinput>"
msgstr ""

#. type: Content of: <sect1><sect2><para>
#: en/chapter08/tcl.xml:117
msgid "Install Tcl's headers. The next package, Expect, requires them."
msgstr ""

#. type: Content of: <sect1><sect2><screen>
#: en/chapter08/tcl.xml:119
#, no-wrap
msgid "<userinput remap=\"install\">make install-private-headers</userinput>"
msgstr ""

#. type: Content of: <sect1><sect2><para>
