"<userinput remap=\"pre\">mkdir build\n"
"pushd build\n"
"  ../configure --disable-bzlib      \\\n"
"               --disable-libseccomp \\\n"
"               --disable-xzlib      \\\n"
"               --disable-zlib\n"
"  make\n"
"popd</userinput>"
msgstr ""
"<userinput remap=\"pre\">mkdir build\n"
"pushd build\n"
"  ../configure --disable-bzlib      \\\n"
"               --disable-libseccomp \\\n"
"               --disable-xzlib      \\\n"
"               --disable-zlib\n"
"  make\n"
"popd</userinput>"

#. type: Content of: <sect1><sect2><variablelist><title>
#: en/chapter06/file.xml:63 en/chapter07/bison.xml:52 en/chapter08/bash.xml:51
#: en/chapter08/readline.xml:77
msgid "The meaning of the new configure option:"
msgstr ""

