msgstr "template"

#. type: Content of: <sect1><sect2><variablelist><varlistentry><term>
#: en/chapter09/bootscripts.xml:305
msgid "<command>udev</command>"
msgstr "<command>udev</command>"

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><para>
#: en/chapter09/bootscripts.xml:307
msgid ""
"Prepares the <filename class=\"directory\">/dev</filename> directory and "
"starts the udev daemon"
msgstr ""
"Prepares the <filename class=\"directory\">/dev</filename> directory and "
"starts the udev daemon"

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><indexterm><primary>
#: en/chapter09/bootscripts.xml:310
