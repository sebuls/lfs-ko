msgstr ""

#. type: Content of: <sect1><sect2><informaltable><tgroup><thead><row><entry>
#: en/part3intro/toolchaintechnotes.xml:103
#: en/part3intro/toolchaintechnotes.xml:137
#: en/part3intro/toolchaintechnotes.xml:320
