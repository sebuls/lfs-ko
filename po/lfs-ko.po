#. type: Content of: <sect1><sect2><title>
#: en/chapter08/e2fsprogs.xml:45
msgid "Installation of E2fsprogs"
msgstr "Installation of E2fsprogs"

#. type: Content of: <sect1><sect2><para>
#: en/chapter08/e2fsprogs.xml:47
msgid ""
"The E2fsprogs documentation recommends that the package be built in a "
"subdirectory of the source tree:"
msgstr ""

#. type: Content of: <sect1><sect2><para>
#: en/chapter08/e2fsprogs.xml:53
msgid "Prepare E2fsprogs for compilation:"
msgstr "Prepare E2fsprogs for compilation:"

#. type: Content of: <sect1><sect2><screen>
#: en/chapter08/e2fsprogs.xml:55
#, no-wrap
msgid ""
"<userinput remap=\"configure\">../configure --prefix=/usr       \\\n"
"             --sysconfdir=/etc   \\\n"
"             --enable-elf-shlibs \\\n"
"             --disable-libblkid  \\\n"
"             --disable-libuuid   \\\n"
"             --disable-uuidd     \\\n"
"             --disable-fsck</userinput>"
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><term>
#: en/chapter08/e2fsprogs.xml:67
msgid "<parameter>--enable-elf-shlibs</parameter>"
msgstr "<parameter>--enable-elf-shlibs</parameter>"

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><para>
#: en/chapter08/e2fsprogs.xml:69
msgid ""
"This creates the shared libraries which some programs in this package use."
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><para>
#: en/chapter08/e2fsprogs.xml:77
msgid ""
"These prevent building and installing the <systemitem "
"class=\"library\">libuuid</systemitem> and <systemitem "
"class=\"library\">libblkid</systemitem> libraries, the <systemitem "
"class=\"daemon\">uuidd</systemitem> daemon, and the <command>fsck</command> "
"wrapper; util-linux installs more recent versions."
msgstr ""

#. type: Content of: <sect1><sect2><para>
#: en/chapter08/e2fsprogs.xml:92
msgid "To run the tests, issue:"
msgstr ""

#. type: Content of: <sect1><sect2><para>
#: en/chapter08/e2fsprogs.xml:98
msgid ""
"One test named <filename>m_assume_storage_prezeroed</filename> is known to "
"fail.  Another test named <filename>m_rootdir_acl</filename> is known to "
"fail if the file system used for the LFS system is not <systemitem "
"class='filesystem'>ext4</systemitem>."
msgstr ""

#. type: Content of: <sect1><sect2><para>
#: en/chapter08/e2fsprogs.xml:121
msgid "Remove useless static libraries:"
msgstr "Remove useless static libraries:"

#. type: Content of: <sect1><sect2><screen>
#: en/chapter08/e2fsprogs.xml:123
#, no-wrap
msgid "<userinput remap=\"install\">rm -fv /usr/lib/{libcom_err,libe2p,libext2fs,libss}.a</userinput>"
msgstr ""

#. type: Content of: <sect1><sect2><para>
#: en/chapter08/e2fsprogs.xml:125
msgid ""
"This package installs a gzipped <filename class=\"extension\">.info</"
"filename> file but doesn't update the system-wide <filename>dir</filename> "
"file. Unzip this file and then update the system <filename>dir</filename> "
"file using the following commands:"
msgstr ""

#. type: Content of: <sect1><sect2><screen>
#: en/chapter08/e2fsprogs.xml:131
#, no-wrap
msgid ""
"<userinput remap=\"install\">gunzip -v /usr/share/info/libext2fs.info.gz\n"
"install-info --dir-file=/usr/share/info/dir /usr/share/info/libext2fs.info</userinput>"
msgstr ""

#. type: Content of: <sect1><sect2><para>
#: en/chapter08/e2fsprogs.xml:134
msgid ""
"If desired, create and install some additional documentation by issuing the "
"following commands:"
msgstr ""

#. type: Content of: <sect1><sect2><screen>
#: en/chapter08/e2fsprogs.xml:137
#, no-wrap
msgid ""
"<userinput remap=\"install\">makeinfo -o      doc/com_err.info ../lib/et/com_err.texinfo\n"
"install -v -m644 doc/com_err.info /usr/share/info\n"
"install-info --dir-file=/usr/share/info/dir /usr/share/info/com_err.info</userinput>"
msgstr ""

#. type: Content of: <sect1><sect2><title>
#: en/chapter08/e2fsprogs.xml:143
msgid "Configuring E2fsprogs"
msgstr ""

#. type: Content of: <sect1><sect2><indexterm><primary>
#: en/chapter08/e2fsprogs.xml:146
msgid "/etc/mke2fs.conf"
msgstr "/etc/mke2fs.conf"

#. type: Content of: <sect1><sect2><para>
#: en/chapter08/e2fsprogs.xml:150
msgid ""
"<filename>/etc/mke2fs.conf</filename> contains the default value of various "
"command line options of <command>mke2fs</command>.  You may edit the file to "
"make the default values suitable for your needs.  For example, some "
"utilities (not in LFS or BLFS) cannot recognize a <systemitem "
"class='filesystem'>ext4</systemitem> file system with "
"<literal>metadata_csum_seed</literal> feature enabled.  <emphasis "
"role='bold'>If</emphasis> you need such a utility, you may remove the "
"feature from the default <systemitem class='filesystem'>ext4</systemitem> "
"feature list with the command:"
msgstr ""
"<filename>/etc/mke2fs.conf</filename> contains the default value of various "
"command line options of <command>mke2fs</command>.  You may edit the file to "
"make the default values suitable for your needs.  For example, some "
"utilities (not in LFS or BLFS) cannot recognize a <systemitem "
"class='filesystem'>ext4</systemitem> file system with "
"<literal>metadata_csum_seed</literal> feature enabled.  <emphasis "
"role='bold'>If</emphasis> you need such a utility, you may remove the "
"feature from the default <systemitem class='filesystem'>ext4</systemitem> "
"feature list with the command:"

#. type: Content of: <sect1><sect2><screen>
#: en/chapter08/e2fsprogs.xml:162
#, no-wrap
msgid "<userinput>sed 's/metadata_csum_seed,//' -i /etc/mke2fs.conf</userinput>"
msgstr ""

#. type: Content of: <sect1><sect2><para>
#: en/chapter08/e2fsprogs.xml:165
msgid ""
"Read the man page <ulink role='man' url='&man;mke2fs.conf.5'>mke2fs.conf(5)</"
"ulink> for details."
msgstr ""
"Read the man page <ulink role='man' url='&man;mke2fs.conf.5'>mke2fs.conf(5)</"
"ulink> for details."

