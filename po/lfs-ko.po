#. type: Content of: <sect1><sect2><title>
#: en/chapter08/sqlite.xml:43
msgid "Installation of Sqlite"
msgstr "Sqlite 설치"

#. type: Content of: <sect1><sect2><para>
#: en/chapter08/sqlite.xml:45
msgid "Unpack the documentation:"
msgstr ""

#. type: Content of: <sect1><sect2><screen>
#: en/chapter08/sqlite.xml:47
#, no-wrap
msgid "<userinput remap=\"pre\">tar -xf ../sqlite-doc-&sqlite-doc-version;.tar.xz</userinput>"
msgstr "<userinput remap=\"pre\">tar -xf ../sqlite-doc-&sqlite-doc-version;.tar.xz</userinput>"

#. type: Content of: <sect1><sect2><para>
#: en/chapter08/sqlite.xml:49
msgid "Prepare Sqlite for compilation with:"
msgstr ""

#. type: Content of: <sect1><sect2><screen>
#: en/chapter08/sqlite.xml:51
#, no-wrap
msgid ""
"<userinput remap=\"configure\">./configure --prefix=/usr     \\\n"
"            --disable-static  \\\n"
"            --enable-fts{4,5} \\\n"
"            CPPFLAGS=\"-D SQLITE_ENABLE_COLUMN_METADATA=1 \\\n"
"                      -D SQLITE_ENABLE_UNLOCK_NOTIFY=1   \\\n"
"                      -D SQLITE_ENABLE_DBSTAT_VTAB=1     \\\n"
"                      -D SQLITE_SECURE_DELETE=1\"</userinput>"
msgstr ""
"<userinput remap=\"configure\">./configure --prefix=/usr     \\\n"
"            --disable-static  \\\n"
"            --enable-fts{4,5} \\\n"
"            CPPFLAGS=\"-D SQLITE_ENABLE_COLUMN_METADATA=1 \\\n"
"                      -D SQLITE_ENABLE_UNLOCK_NOTIFY=1   \\\n"
"                      -D SQLITE_ENABLE_DBSTAT_VTAB=1     \\\n"
"                      -D SQLITE_SECURE_DELETE=1\"</userinput>"

#. type: Content of: <sect1><sect2><variablelist><varlistentry><term>
#: en/chapter08/sqlite.xml:62
msgid "<parameter>--enable-fts{4,5}</parameter>"
msgstr "<parameter>--enable-fts{4,5}</parameter>"

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><para>
#: en/chapter08/sqlite.xml:64
msgid ""
"These switches enable support for version 4 and 5 of the full text search "
"(FTS) extension."
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><term>
#: en/chapter08/sqlite.xml:70
msgid ""
"<parameter>CPPFLAGS=\"-D SQLITE_ENABLE_COLUMN_METADATA=1 ...</parameter>"
msgstr ""
"<parameter>CPPFLAGS=\"-D SQLITE_ENABLE_COLUMN_METADATA=1 ...</parameter>"

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><para>
#: en/chapter08/sqlite.xml:72
msgid ""
"Some applications require these options to be turned on. The only way to do "
"this is to include them in the CFLAGS or CPPFLAGS. We use the latter so the "
"default value (or any value set by the user) of CFLAGS won't be affected. "
"For further information on what can be specified see https://www.sqlite.org/"
"compile.html."
msgstr ""

#. type: Content of: <sect1><sect2><screen>
#: en/chapter08/sqlite.xml:84
#, no-wrap
msgid "<userinput remap=\"make\">make LDFLAGS.rpath=\"\"</userinput>"
msgstr "<userinput remap=\"make\">make LDFLAGS.rpath=\"\"</userinput>"

#. type: Content of: <sect1><sect2><para>
#: en/chapter08/sqlite.xml:86
msgid ""
"The <parameter>LDFLAGS.rpath=\"\"</parameter> option prevents hard coding "
"library search paths (rpath) into the shared library.  This package does not "
"need rpath for an installation into the standard location, and rpath may "
"sometimes cause unwanted effects or even security issues."
