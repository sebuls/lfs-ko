msgid ""
"<productname>packaging</productname> <productnumber>&packaging-version;</"
"productnumber> <placeholder type=\"address\" id=\"0\"/>"
msgstr ""
"<productname>packaging</productname> <productnumber>&packaging-version;</"
"productnumber> <placeholder type=\"address\" id=\"0\"/>"

