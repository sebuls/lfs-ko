#: en/chapter08/xml-parser.xml:48 en/chapter08/xz.xml:53
#: en/chapter08/zlib.xml:48 en/chapter08/zstd.xml:45
msgid "Compile the package:"
msgstr ""

#. type: Content of: <sect1><sect2><warning><para>
#: en/chapter05/glibc.xml:160
msgid ""
"If <envar>LFS</envar> is not properly set, and despite the recommendations, "
"you are building as <systemitem class=\"username\">root</systemitem>, the "
"next command will install the newly built Glibc to your host system, which "
"will almost certainly render it unusable. So double-check that the "
"environment is correctly set, and that you are not &root;, before running "
"the following command."
msgstr ""

#. type: Content of: <sect1><sect2><screen>
#: en/chapter05/glibc.xml:167 en/chapter05/libstdc++.xml:122
#: en/chapter06/bash.xml:75 en/chapter06/binutils-pass2.xml:107
#: en/chapter06/coreutils.xml:74 en/chapter06/diffutils.xml:86
#: en/chapter06/file.xml:87 en/chapter06/findutils.xml:59
#: en/chapter06/gawk.xml:62 en/chapter06/gcc-pass2.xml:164
#: en/chapter06/grep.xml:58 en/chapter06/gzip.xml:56 en/chapter06/m4.xml:58
#: en/chapter06/make.xml:57 en/chapter06/patch.xml:58 en/chapter06/sed.xml:58
#: en/chapter06/tar.xml:58 en/chapter06/xz.xml:60
#, no-wrap
msgid "<userinput remap=\"install\">make DESTDIR=$LFS install</userinput>"
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><title>
#: en/chapter05/glibc.xml:170
msgid "The meaning of the <command>make install</command> option:"
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><term>
#: en/chapter05/glibc.xml:173
msgid "<parameter>DESTDIR=$LFS</parameter>"
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><para>
#: en/chapter05/glibc.xml:175
msgid ""
"The <envar>DESTDIR</envar> make variable is used by almost all packages to "
"define the location where the package should be installed. If it is not set, "
"it defaults to the root (<filename class=\"directory\">/</filename>) "
"directory. Here we specify that the package is installed in <filename "
"class=\"directory\"> $LFS</filename>, which will become the root directory "
"in <xref linkend= \"ch-tools-chroot\" role='.'/>"
msgstr ""

#. type: Content of: <sect1><sect2><para>
#: en/chapter05/glibc.xml:187
msgid ""
"Fix a hard coded path to the executable loader in the <command>ldd</command> "
"script:"
msgstr ""

#. type: Content of: <sect1><sect2><screen>
#: en/chapter05/glibc.xml:190
#, no-wrap
msgid "<userinput remap=\"install\">sed '/RTLDLIST=/s@/usr@@g' -i $LFS/usr/bin/ldd</userinput>"
msgstr ""

#. type: Content of: <sect1><sect2><para>
#: en/chapter05/glibc.xml:192
msgid ""
"Now that our cross toolchain is in place, it is important to ensure that "
"compiling and linking will work as expected. We do this by performing some "
"sanity checks:"
msgstr ""

#. type: Content of: <sect1><sect2><screen>
#: en/chapter05/glibc.xml:196
#, no-wrap
msgid ""
"<userinput>echo 'int main(){}' | $LFS_TGT-gcc -x c - -v -Wl,--verbose &amp;&gt; dummy.log\n"
"readelf -l a.out | grep ': /lib'</userinput>"
msgstr ""

#. type: Content of: <sect1><sect2><para>
#: en/chapter05/glibc.xml:199 en/chapter08/gcc.xml:261
msgid ""
"There should be no errors, and the output of the last command will be "
"(allowing for platform-specific differences in the dynamic linker name):"
msgstr ""

#. type: Content of: <sect1><sect2><screen>
#: en/chapter05/glibc.xml:203 en/chapter08/gcc.xml:265
#, no-wrap
msgid "<computeroutput>[Requesting program interpreter: /lib64/ld-linux-x86-64.so.2]</computeroutput>"
msgstr "<computeroutput>[Requesting program interpreter: /lib64/ld-linux-x86-64.so.2]</computeroutput>"

#. type: Content of: <sect1><sect2><para>
#: en/chapter05/glibc.xml:205
msgid ""
"Note that this path should not contain <filename class='directory'>/mnt/lfs</"
"filename> (or the value of the <envar>LFS</envar> variable if you used a "
"different one).  The path is resolved when the compiled program is executed, "
"and that should only happen after we enter the chroot environment where the "
"kernel would consider <filename class='directory'>$LFS</filename> as the "
"root directory (<filename class='directory'>/</filename>)."
msgstr ""

#. type: Content of: <sect1><sect2><para>
#: en/chapter05/glibc.xml:213 en/chapter08/gcc.xml:267
msgid "Now make sure that we're set up to use the correct start files:"
msgstr ""

#. type: Content of: <sect1><sect2><screen>
#: en/chapter05/glibc.xml:215
#, no-wrap
msgid "<userinput>grep -E -o \"$LFS/lib.*/S?crt[1in].*succeeded\" dummy.log</userinput>"
msgstr ""

#. type: Content of: <sect1><sect2><para>
#: en/chapter05/glibc.xml:217 en/chapter05/glibc.xml:263
#: en/chapter08/gcc.xml:271 en/chapter08/gcc.xml:332
msgid "The output of the last command should be:"
msgstr ""

#. type: Content of: <sect1><sect2><screen>
#: en/chapter05/glibc.xml:219
#, no-wrap
msgid ""
"<computeroutput>/mnt/lfs/lib/../lib/Scrt1.o succeeded\n"
"/mnt/lfs/lib/../lib/crti.o succeeded\n"
"/mnt/lfs/lib/../lib/crtn.o succeeded</computeroutput>"
msgstr ""
"<computeroutput>/mnt/lfs/lib/../lib/Scrt1.o succeeded\n"
"/mnt/lfs/lib/../lib/crti.o succeeded\n"
"/mnt/lfs/lib/../lib/crtn.o succeeded</computeroutput>"

#. type: Content of: <sect1><sect2><para>
#: en/chapter05/glibc.xml:223 en/chapter08/gcc.xml:284
msgid "Verify that the compiler is searching for the correct header files:"
msgstr ""

#. type: Content of: <sect1><sect2><screen>
#: en/chapter05/glibc.xml:226
#, no-wrap
msgid "<userinput>grep -B3 \"^ $LFS/usr/include\" dummy.log</userinput>"
msgstr ""

#. type: Content of: <sect1><sect2><para>
#: en/chapter05/glibc.xml:228 en/chapter08/gcc.xml:289
msgid "This command should return the following output:"
msgstr ""

#. type: Content of: <sect1><sect2><screen>
#: en/chapter05/glibc.xml:230
#, no-wrap
msgid ""
"<computeroutput>#include &lt;...&gt; search starts here:\n"
" /mnt/lfs/tools/lib/gcc/x86_64-lfs-linux-gnu/&gcc-version;/include\n"
" /mnt/lfs/tools/lib/gcc/x86_64-lfs-linux-gnu/&gcc-version;/include-fixed\n"
" /mnt/lfs/usr/include</computeroutput>"
msgstr ""
"<computeroutput>#include &lt;...&gt; search starts here:\n"
" /mnt/lfs/tools/lib/gcc/x86_64-lfs-linux-gnu/&gcc-version;/include\n"
" /mnt/lfs/tools/lib/gcc/x86_64-lfs-linux-gnu/&gcc-version;/include-fixed\n"
" /mnt/lfs/usr/include</computeroutput>"

#. type: Content of: <sect1><sect2><para>
#: en/chapter05/glibc.xml:235 en/chapter08/gcc.xml:297
msgid ""
"Again, the directory named after your target triplet may be different than "
"the above, depending on your system architecture."
msgstr ""

#. type: Content of: <sect1><sect2><para>
#: en/chapter05/glibc.xml:238 en/chapter08/gcc.xml:300
msgid ""
"Next, verify that the new linker is being used with the correct search paths:"
msgstr ""

#. type: Content of: <sect1><sect2><screen>
#: en/chapter05/glibc.xml:240 en/chapter08/gcc.xml:302
#, no-wrap
msgid "<userinput>grep 'SEARCH.*/usr/lib' dummy.log |sed 's|; |\\n|g'</userinput>"
msgstr ""

#. type: Content of: <sect1><sect2><para>
#: en/chapter05/glibc.xml:242 en/chapter08/gcc.xml:304
msgid ""
"References to paths that have components with '-linux-gnu' should be "
"ignored, but otherwise the output of the last command should be:"
msgstr ""
"References to paths that have components with '-linux-gnu' should be "
"ignored, but otherwise the output of the last command should be:"

#. type: Content of: <sect1><sect2><screen>
#: en/chapter05/glibc.xml:245
#, no-wrap
msgid ""
"<computeroutput>SEARCH_DIR(\"=/mnt/lfs/tools/x86_64-lfs-linux-gnu/lib64\")\n"
"SEARCH_DIR(\"=/usr/local/lib64\")\n"
"SEARCH_DIR(\"=/lib64\")\n"
"SEARCH_DIR(\"=/usr/lib64\")\n"
"SEARCH_DIR(\"=/mnt/lfs/tools/x86_64-lfs-linux-gnu/lib\")\n"
"SEARCH_DIR(\"=/usr/local/lib\")\n"
"SEARCH_DIR(\"=/lib\")\n"
"SEARCH_DIR(\"=/usr/lib\");</computeroutput>"
msgstr ""
"<computeroutput>SEARCH_DIR(\"=/mnt/lfs/tools/x86_64-lfs-linux-gnu/lib64\")\n"
"SEARCH_DIR(\"=/usr/local/lib64\")\n"
"SEARCH_DIR(\"=/lib64\")\n"
"SEARCH_DIR(\"=/usr/lib64\")\n"
"SEARCH_DIR(\"=/mnt/lfs/tools/x86_64-lfs-linux-gnu/lib\")\n"
"SEARCH_DIR(\"=/usr/local/lib\")\n"
"SEARCH_DIR(\"=/lib\")\n"
"SEARCH_DIR(\"=/usr/lib\");</computeroutput>"

#. type: Content of: <sect1><sect2><para>
#: en/chapter05/glibc.xml:254
msgid ""
"A 32-bit system may use a few other directories, but anyway the important "
"facet here is all the paths should begin with an equal sign (<literal>=</"
"literal>), which would be replaced with the sysroot directory that we've "
"configured for the linker."
msgstr ""

#. type: Content of: <sect1><sect2><para>
#: en/chapter05/glibc.xml:259 en/chapter08/gcc.xml:328
msgid "Next make sure that we're using the correct libc:"
msgstr ""

#. type: Content of: <sect1><sect2><screen>
#: en/chapter05/glibc.xml:261 en/chapter08/gcc.xml:330
#, no-wrap
msgid "<userinput>grep \"/lib.*/libc.so.6 \" dummy.log</userinput>"
msgstr ""

#. type: Content of: <sect1><sect2><screen>
#: en/chapter05/glibc.xml:265
#, no-wrap
msgid "<computeroutput>attempt to open /mnt/lfs/usr/lib/libc.so.6 succeeded</computeroutput>"
msgstr "<computeroutput>attempt to open /mnt/lfs/usr/lib/libc.so.6 succeeded</computeroutput>"

#. type: Content of: <sect1><sect2><para>
#: en/chapter05/glibc.xml:267 en/chapter08/gcc.xml:336
msgid "Make sure GCC is using the correct dynamic linker:"
msgstr "Make sure GCC is using the correct dynamic linker:"

#. type: Content of: <sect1><sect2><screen>
#: en/chapter05/glibc.xml:269 en/chapter08/gcc.xml:338
#, no-wrap
msgid "<userinput>grep found dummy.log</userinput>"
msgstr ""

#. type: Content of: <sect1><sect2><para>
#: en/chapter05/glibc.xml:271 en/chapter08/gcc.xml:340
msgid ""
"The output of the last command should be (allowing for platform-specific "
"differences in dynamic linker name):"
msgstr ""

#. type: Content of: <sect1><sect2><screen>
#: en/chapter05/glibc.xml:274
#, no-wrap
msgid "<computeroutput>found ld-linux-x86-64.so.2 at /mnt/lfs/usr/lib/ld-linux-x86-64.so.2</computeroutput>"
msgstr "<computeroutput>found ld-linux-x86-64.so.2 at /mnt/lfs/usr/lib/ld-linux-x86-64.so.2</computeroutput>"

#. The most likely
#.   reason is that something went wrong with the specs file adjustment.
#. type: Content of: <sect1><sect2><para>
