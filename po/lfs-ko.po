#: en/chapter08/procps.xml:114
msgid "/usr/include/procps and /usr/share/doc/procps-ng-&procps-ng-version;"
msgstr "/usr/include/procps and /usr/share/doc/procps-ng-&procps-ng-version;"

#. type: Content of: <sect1><sect2><variablelist><varlistentry><term>
#: en/chapter08/procps.xml:124
msgid "<command>free</command>"
msgstr "<command>free</command>"

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><para>
#: en/chapter08/procps.xml:126
msgid ""
"Reports the amount of free and used memory (both physical and swap memory) "
"in the system"
msgstr ""
"Reports the amount of free and used memory (both physical and swap memory) "
"in the system"

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><indexterm><primary>
#: en/chapter08/procps.xml:129
