"sort   /dev/null || bail \"sort does not work\"\n"
"\n"
"ver_check()\n"
"{\n"
"   if ! type -p $2 &amp;>/dev/null\n"
"   then \n"
"     echo \"ERROR: Cannot find $2 ($1)\"; return 1; \n"
"   fi\n"
"   v=$($2 --version 2>&amp;1 | grep -E -o '[0-9]+\\.[0-9\\.]+[a-z]*' | head -n1)\n"
"   if printf '%s\\n' $3 $v | sort --version-sort --check &amp;>/dev/null\n"
"   then \n"
"     printf \"OK:    %-9s %-6s >= $3\\n\" \"$1\" \"$v\"; return 0;\n"
"   else \n"
"     printf \"ERROR: %-9s is TOO OLD ($3 or later required)\\n\" \"$1\"; \n"
"     return 1; \n"
"   fi\n"
"}\n"
"\n"
"ver_kernel()\n"
"{\n"
"   kver=$(uname -r | grep -E -o '^[0-9\\.]+')\n"
"   if printf '%s\\n' $1 $kver | sort --version-sort --check &amp;>/dev/null\n"
"   then \n"
"     printf \"OK:    Linux Kernel $kver >= $1\\n\"; return 0;\n"
"   else \n"
"     printf \"ERROR: Linux Kernel ($kver) is TOO OLD ($1 or later required)\\n\" \"$kver\"; \n"
"     return 1; \n"
"   fi\n"
"}\n"
"\n"
"# Coreutils first because --version-sort needs Coreutils >= 7.0\n"
"ver_check Coreutils      sort     8.1 || bail \"Coreutils too old, stop\"\n"
"ver_check Bash           bash     3.2\n"
"ver_check Binutils       ld       2.13.1\n"
"ver_check Bison          bison    2.7\n"
"ver_check Diffutils      diff     2.8.1\n"
"ver_check Findutils      find     4.2.31\n"
"ver_check Gawk           gawk     4.0.1\n"
"ver_check GCC            gcc      5.4\n"
"ver_check \"GCC (C++)\"    g++      5.4\n"
"ver_check Grep           grep     2.5.1a\n"
"ver_check Gzip           gzip     1.3.12\n"
"ver_check M4             m4       1.4.10\n"
"ver_check Make           make     4.0\n"
"ver_check Patch          patch    2.5.4\n"
"ver_check Perl           perl     5.8.8\n"
"ver_check Python         python3  3.4\n"
"ver_check Sed            sed      4.1.5\n"
"ver_check Tar            tar      1.22\n"
"ver_check Texinfo        texi2any 5.0\n"
"ver_check Xz             xz       5.0.0\n"
"ver_kernel &min-kernel;\n"
"\n"
"if mount | grep -q 'devpts on /dev/pts' &amp;&amp; [ -e /dev/ptmx ]\n"
"then echo \"OK:    Linux Kernel supports UNIX 98 PTY\";\n"
"else echo \"ERROR: Linux Kernel does NOT support UNIX 98 PTY\"; fi\n"
"\n"
"alias_check() {\n"
"   if $1 --version 2>&amp;1 | grep -qi $2\n"
"   then printf \"OK:    %-4s is $2\\n\" \"$1\";\n"
"   else printf \"ERROR: %-4s is NOT $2\\n\" \"$1\"; fi\n"
"}\n"
"echo \"Aliases:\"\n"
"alias_check awk GNU\n"
"alias_check yacc Bison\n"
"alias_check sh Bash\n"
"\n"
"echo \"Compiler check:\"\n"
"if printf \"int main(){}\" | g++ -x c++ -\n"
"then echo \"OK:    g++ works\";\n"
"else echo \"ERROR: g++ does NOT work\"; fi\n"
"rm -f a.out\n"
"\n"
"if [ \"$(nproc)\" = \"\" ]; then\n"
"   echo \"ERROR: nproc is not available or it produces empty output\"\n"
"else\n"
"   echo \"OK: nproc reports $(nproc) logical cores are available\"\n"
"fi</literal>\n"
"EOF\n"
"\n"
"bash version-check.sh</userinput>"

#. type: Content of: <sect1><para>
#: en/chapter02/introduction.xml:13
msgid ""
"In this chapter, the host tools needed for building LFS are checked and, if "
"necessary, installed.  Then a partition which will host the LFS system is "
"prepared. We will create the partition itself, create a file system on it, "
"and mount it."
msgstr ""
"이 장에서는 LFS를 빌드하는 데 필요한 호스트 도구를 점검하고, 필요하면 설치합"
"니다. 그 다음 LFS 시스템을 구축할 파티션을 준비합니다. 파티션 자체를 생성하"
"고, 그 위에 파일 시스템을 만든 뒤 마운트할 것입니다."

#. type: Content of: <sect1><title>
#: en/chapter02/mounting.xml:11
msgid "Mounting the New Partition"
msgstr "새 파티션 마운트"

#. type: Content of: <sect1><para>
#: en/chapter02/mounting.xml:13
msgid ""
"Now that a file system has been created, the partition must be mounted so "
"the host system can access it. This book assumes that the file system is "
"mounted at the directory specified by the <envar>LFS</envar> environment "
"variable described in the previous section."
msgstr ""

#. type: Content of: <sect1><para>
#: en/chapter02/mounting.xml:19
msgid ""
"Strictly speaking, one cannot <quote>mount a partition.</quote> One mounts "
"the <emphasis>file system</emphasis> embedded in that partition. But since a "
"single partition can't contain more than one file system, people often speak "
"of the partition and the associated file system as if they were one and the "
"same."
msgstr ""

#. type: Content of: <sect1><para>
#: en/chapter02/mounting.xml:24
msgid ""
"Create the mount point and mount the LFS file system with these commands:"
msgstr ""

#. type: Content of: <sect1><screen>
#: en/chapter02/mounting.xml:26
#, no-wrap
msgid ""
"<userinput>mkdir -pv $LFS\n"
"mount -v -t ext4 /dev/<replaceable>&lt;xxx&gt;</replaceable> $LFS</userinput>"
msgstr ""

#. type: Content of: <sect1><para>
#: en/chapter02/mounting.xml:32
msgid ""
"If you are using multiple partitions for LFS (e.g., one for <filename "
"class=\"directory\">/</filename> and another for <filename "
"class=\"directory\">/home</filename>), mount them like this:"
msgstr ""

#. type: Content of: <sect1><screen>
#: en/chapter02/mounting.xml:36
#, no-wrap
msgid ""
"<userinput>mkdir -pv $LFS\n"
"mount -v -t ext4 /dev/<replaceable>&lt;xxx&gt;</replaceable> $LFS\n"
"mkdir -v $LFS/home\n"
"mount -v -t ext4 /dev/<replaceable>&lt;yyy&gt;</replaceable> $LFS/home</userinput>"
msgstr ""

#. type: Content of: <sect1><para>
#: en/chapter02/mounting.xml:41
msgid ""
"Replace <replaceable>&lt;xxx&gt;</replaceable> and <replaceable>&lt;yyy&gt;</"
"replaceable> with the appropriate partition names."
msgstr ""
"Replace <replaceable>&lt;xxx&gt;</replaceable> and <replaceable>&lt;yyy&gt;</"
"replaceable> with the appropriate partition names."

#. type: Content of: <sect1><para>
#: en/chapter02/mounting.xml:45
msgid ""
"Set the owner and permission mode of the <filename class='directory'>$LFS</"
"filename> directory (i.e. the root directory in the newly created file "
"system for the LFS system) to &root; and <literal>755</literal> in case the "
"host distro has been configured to use a different default for "
"<command>mkfs</command>:"
msgstr ""

#. type: Content of: <sect1><screen>
#: en/chapter02/mounting.xml:51
#, no-wrap
msgid ""
"<userinput>chown root:root $LFS\n"
"chmod 755 $LFS</userinput>"
msgstr ""

#. type: Content of: <sect1><para>
#: en/chapter02/mounting.xml:54
msgid ""
"Ensure that this new partition is not mounted with permissions that are too "
"restrictive (such as the <option>nosuid</option> or <option>nodev</option> "
"options). Run the <command>mount</command> command without any parameters to "
"see what options are set for the mounted LFS partition. If <option>nosuid</"
"option> and/or <option>nodev</option> are set, the partition must be "
"remounted."
msgstr ""

#. type: Content of: <sect1><warning><para><screen>
#: en/chapter02/mounting.xml:68
#, no-wrap
msgid "/dev/<replaceable>&lt;xxx&gt;</replaceable>  /mnt/lfs ext4   defaults      1     1"
msgstr "/dev/<replaceable>&lt;xxx&gt;</replaceable>  /mnt/lfs ext4   defaults      1     1"

#. type: Content of: <sect1><warning><para>
#: en/chapter02/mounting.xml:61
msgid ""
"The above instructions assume that you will not restart your computer "
"throughout the LFS process.  If you shut down your system, you will either "
"need to remount the LFS partition each time you restart the build process, "
"or modify the host system's &fstab; file to automatically remount it when "
"you reboot. For example, you might add this line to your &fstab; file: "
"<placeholder type=\"screen\" id=\"0\"/> If you use additional optional "
"partitions, be sure to add them also."
msgstr ""

#. type: Content of: <sect1><para>
#: en/chapter02/mounting.xml:75
msgid ""
"If you are using a <systemitem class=\"filesystem\">swap</systemitem> "
"partition, ensure that it is enabled using the <command>swapon</command> "
"command:"
msgstr ""

#. type: Content of: <sect1><screen>
#: en/chapter02/mounting.xml:79
#, no-wrap
msgid "<userinput>/sbin/swapon -v /dev/<replaceable>&lt;zzz&gt;</replaceable></userinput>"
msgstr ""

#. type: Content of: <sect1><para>
#: en/chapter02/mounting.xml:81
msgid ""
"Replace <replaceable>&lt;zzz&gt;</replaceable> with the name of the "
"<systemitem class=\"filesystem\">swap</systemitem> partition."
msgstr ""
"Replace <replaceable>&lt;zzz&gt;</replaceable> with the name of the "
"<systemitem class=\"filesystem\">swap</systemitem> partition."

#. type: Content of: <sect1><para>
#: en/chapter02/mounting.xml:84
msgid ""
"Now that the new LFS partition is open for business, it's time to download "
"the packages."
msgstr ""

#. type: Content of: <sect1><title>
#: en/chapter02/stages.xml:11
msgid "Building LFS in Stages"
msgstr "LFS in 스테이지 빌드"

#. type: Content of: <sect1><para>
#: en/chapter02/stages.xml:13
msgid ""
"LFS is designed to be built in one session.  That is, the instructions "
"assume that the system will not be shut down during the process.  This does "
"not mean that the system has to be built in one sitting.  The issue is that "
"certain procedures must be repeated after a reboot when resuming LFS at "
"different points."
msgstr ""
"LFS is designed to be built in one session.  That is, the instructions "
"assume that the system will not be shut down during the process.  This does "
"not mean that the system has to be built in one sitting.  The issue is that "
"certain procedures must be repeated after a reboot when resuming LFS at "
"different points."

#. type: Content of: <sect1><sect2><title>
#: en/chapter02/stages.xml:21
msgid "Chapters&nbsp;1&ndash;4"
msgstr "제1&ndash;4장"

#. type: Content of: <sect1><sect2><para>
#: en/chapter02/stages.xml:23
msgid ""
"These chapters run commands on the host system.  When restarting, be certain "
"of one thing:"
msgstr ""

#. type: Content of: <sect1><sect2><itemizedlist><listitem><para>
#: en/chapter02/stages.xml:28
msgid ""
"Procedures performed as the <systemitem class=\"username\">root</systemitem> "
"user after Section 2.4 must have the LFS environment variable set "
"<emphasis>FOR THE ROOT USER</emphasis>."
msgstr ""
"Procedures performed as the <systemitem class=\"username\">root</systemitem> "
"user after Section 2.4 must have the LFS environment variable set "
"<emphasis>FOR THE ROOT USER</emphasis>."

#. type: Content of: <sect1><sect2><title>
#: en/chapter02/stages.xml:37
msgid "Chapters&nbsp;5&ndash;6"
msgstr "제5&ndash;6장"

#. type: Content of: <sect1><sect2><itemizedlist><listitem><para>
#: en/chapter02/stages.xml:41 en/chapter02/stages.xml:67
msgid "The /mnt/lfs partition must be mounted."
msgstr ""

#. type: Content of: <sect1><sect2><itemizedlist><listitem><para>
#: en/chapter02/stages.xml:45
msgid ""
"These two chapters <emphasis>must</emphasis> be done as user <systemitem "
"class=\"username\">lfs</systemitem>.  A <command>su - lfs</command> command "
"must be issued before performing any task in these chapters. If you don't do "
"that, you are at risk of installing packages to the host, and potentially "
"rendering it unusable."
msgstr ""

#. type: Content of: <sect1><sect2><itemizedlist><listitem><para>
#: en/chapter02/stages.xml:53
msgid ""
"The procedures in <xref linkend='ch-tools-generalinstructions'/> are "
"critical.  If there is any doubt a package has been installed correctly, "
"ensure the previously expanded tarball has been removed, then re-extract the "
"package, and complete all the instructions in that section."
msgstr ""

#. type: Content of: <sect1><sect2><title>
#: en/chapter02/stages.xml:63
msgid "Chapters&nbsp;7&ndash;10"
msgstr "제7&ndash;10장"

#. type: Content of: <sect1><sect2><itemizedlist><listitem><para>
#: en/chapter02/stages.xml:71
msgid ""
"A few operations, from <quote>Preparing Virtual Kernel File Systems</quote> "
"to <quote>Entering the Chroot Environment,</quote> must be done as the "
"<systemitem class=\"username\">root</systemitem> user, with the LFS "
"environment variable set for the &root; user."
msgstr ""

#. type: Content of: <sect1><sect2><itemizedlist><listitem><para>
#: en/chapter02/stages.xml:79
msgid ""
"When entering chroot, the LFS environment variable must be set for "
"<systemitem class=\"username\">root</systemitem>. The LFS variable is not "
"used after the chroot environment has been entered."
msgstr ""

#. type: Content of: <sect1><sect2><itemizedlist><listitem><para>
#: en/chapter02/stages.xml:85
msgid ""
"The virtual file systems must be mounted.  This can be done before or after "
"entering chroot by changing to a host virtual terminal and, as <systemitem "
"class=\"username\">root</systemitem>, running the commands in <xref "
"linkend='ch-tools-bindmount'/> and <xref linkend='ch-tools-kernfsmount' "
"role='.'/>"
msgstr ""

#. type: Attribute 'xreflabel' of: <chapter>
#: en/chapter03/chapter03.xml:8
msgid "Chapter&nbsp;3"
msgstr "제3장"

#. type: Content of: <chapter><title>
#: en/chapter03/chapter03.xml:12
msgid "Packages and Patches"
msgstr "패키지 및 패치"

#. type: Content of: <sect1><para>
#: en/chapter03/introduction.xml:13
msgid ""
"This chapter includes a list of packages that need to be downloaded in order "
"to build a basic Linux system. The listed version numbers correspond to "
"versions of the software that are known to work, and this book is based on "
"their use. We highly recommend against using different versions, because the "
"build commands for one version may not work with a different version, unless "
"the different version is specified by an LFS erratum or security advisory.  "
"The newest package versions may also have problems that require work-"
"arounds. These work-arounds will be developed and stabilized in the "
"development version of the book."
msgstr ""
"이 장에는 기본 리눅스 시스템을 빌드하기 위해 다운로드해야 할 패키지 목록이 들"
"어 있습니다. 목록에 기재된 버전 번호는 작동하는 것으로 확인된 소프트웨어 버전"
"이며, 이 책은 해당 버전 사용을 기준으로 작성되었습니다. 다른 버전을 사용하는 "
"것은 강력히 권장하지 않습니다. LFS 정오표나 보안 권고에서 별도로 지정하지 않"
"는 한, 한 버전의 빌드 명령어가 다른 버전에서는 동작 안 할 수 있기 때문입니"
"다. 또한 최신 패키지 버전에는 별도의 해결책(work-around)이 필요한 문제가 있"
"을 수도 있습니다. 이러한 해결책은 이 책의 개발 버전에서 개발되고 안정화될 것"
"입니다."

#. type: Content of: <sect1><para>
#: en/chapter03/introduction.xml:23
msgid ""
"For some packages, the release tarball and the (Git or SVN)  repository "
"snapshot tarball for that release may be published with similar or even "
"identical file names.  But the release tarball may contain some files which "
"are essential despite not stored in the repository (for example, a "
"<command>configure</command> script generated by <command>autoconf</"
"command>), in addition to the contents of the corresponding repository "
"snapshot.  The book uses release tarballs whenever possible. Using a "
"repository snapshot instead of a release tarball specified by the book will "
"cause problems."
msgstr ""
"일부 패키지의 경우, 해당 릴리스를 위한 릴리스 타르볼(tarball)과 (Git 또는 "
"SVN) 저장소 스냅샷 타르볼이 비슷하거나 심지어 동일한 파일 이름으로 게시될 수 "
"있습니다. 그러나 릴리스 타르볼에는 해당 저장소 스냅샷의 내용 외에도, 저장소에"
"는 저장되지 않지만 필수적인 일부 파일들(예를 들어 <command>autoconf</command>"
"로 생성된 <command>configure</command> 스크립트)이 들어 있을 수 있습니다. 이 "
"책에서는 가능한 한 릴리스 타르볼을 사용합니다. 책에서 지정한 릴리스 타르볼 대"
"신 저장소 스냅샷을 사용하면 문제가 생길 수 있습니다."

#. type: Content of: <sect1><para>
#: en/chapter03/introduction.xml:33
msgid ""
"Download locations may not always be accessible. If a download location has "
"changed since this book was published, Google (<ulink url=\"https://"
"www.google.com/\"/>) provides a useful search engine for most packages. If "
"this search is unsuccessful, try one of the alternative means of downloading "
"at <ulink url=\"&lfs-root;lfs/mirrors.html#files\"/>."
msgstr ""

#. type: Content of: <sect1><important><para>
#: en/chapter03/introduction.xml:42
msgid ""
"Listed on the next page are several important packages located at "
"<uri>ftpmirror.gnu.org</uri>.  The canonical location of the subject "
"packages are <uri>ftp.gnu.org</uri> but due to a long term distributed "
"denial of services (DDOS) attack the site administrator suggested the LFS "
"editors to use <uri>ftpmirror.gnu.org</uri> instead.  See <ulink "
"url=\"https://news.slashdot.org/story/25/07/06/1737253/the-fsf-faces-active-"
"ongoing-and-increasing-ddos-attacks\">Slashdot News</ulink> for details."
msgstr ""
"다음 페이지에는 <uri>ftpmirror.gnu.org</uri>에 위치한 몇 가지 중요한 패키지들"
"이 나열되어 있습니다. 해당 패키지의 공식(canonical) 위치는 <uri>ftp.gnu.org</"
"uri>이지만, 장기적인 분산 서비스 거부(DDoS) 공격으로 인해 사이트 관리자가 "
"LFS 편집진에게 대신 <uri>ftpmirror.gnu.org</uri>를 사용하도록 권고했습니다. "
"자세한 내용은 <ulink url=\"https://news.slashdot.org/story/25/07/06/1737253/"
"the-fsf-faces-active-ongoing-and-increasing-ddos-attacks\">슬래시닷 뉴스"
"(Slashdot News)</ulink> 참조하십시오."

#. type: Content of: <sect1><important><para>
#: en/chapter03/introduction.xml:52
msgid ""
"The <uri>ftpmirror.gnu.org</uri> URL actually redirects to one of the "
"mirrors of the <uri>ftp.gnu.org</uri> site.  You may also select a mirror "
"manually instead of using <uri>ftpmirror.gnu.org</uri>.  A list of mirrors "
"is located at <ulink url=\"https://www.gnu.org/prep/ftp.en.html\"/>.  If you "
"choose to use the wget list described below, that file also can be modified "
"to use your desired mirror."
msgstr ""

#. type: Content of: <sect1><para>
#: en/chapter03/introduction.xml:63
msgid ""
"Downloaded packages and patches will need to be stored somewhere that is "
"conveniently available throughout the entire build. A working directory is "
"also required to unpack the sources and build them.  <filename "
"class=\"directory\">$LFS/sources</filename> can be used both as the place to "
"store the tarballs and patches and as a working directory. By using this "
"directory, the required elements will be located on the LFS partition and "
"will be available during all stages of the building process."
msgstr ""

#. type: Content of: <sect1><para>
#: en/chapter03/introduction.xml:72
msgid ""
"To create this directory, execute the following command, as user <systemitem "
"class=\"username\">root</systemitem>, before starting the download session:"
msgstr ""

#. type: Content of: <sect1><screen>
#: en/chapter03/introduction.xml:76
#, no-wrap
msgid "<userinput>mkdir -v $LFS/sources</userinput>"
msgstr "<userinput>mkdir -v $LFS/sources</userinput>"

#. type: Content of: <sect1><para>
#: en/chapter03/introduction.xml:78
msgid ""
"Make this directory writable and sticky. <quote>Sticky</quote> means that "
"even if multiple users have write permission on a directory, only the owner "
"of a file can delete the file within a sticky directory. The following "
"command will enable the write and sticky modes:"
msgstr ""
"Make this directory writable and sticky. <quote>Sticky</quote> means that "
"even if multiple users have write permission on a directory, only the owner "
"of a file can delete the file within a sticky directory. The following "
"command will enable the write and sticky modes:"

#. type: Content of: <sect1><screen>
#: en/chapter03/introduction.xml:84
#, no-wrap
msgid "<userinput>chmod -v a+wt $LFS/sources</userinput>"
msgstr "<userinput>chmod -v a+wt $LFS/sources</userinput>"

#. type: Content of: <sect1><para>
#: en/chapter03/introduction.xml:86
msgid ""
"There are several ways to obtain all the necessary packages and patches to "
"build LFS:"
msgstr ""

#. type: Content of: <sect1><itemizedlist><listitem><para>
#: en/chapter03/introduction.xml:91
msgid ""
"The files can be downloaded individually as described in the next two "
"sections."
msgstr ""

#. type: Content of: <sect1><itemizedlist><listitem><para>
#: en/chapter03/introduction.xml:95
msgid ""
"For stable versions of the book, a tarball of all the needed files can be "
"downloaded from one of the mirror sites listed at <ulink url=\"https://"
"www.linuxfromscratch.org/mirrors.html#files\"/>."
msgstr ""

#. type: Content of: <sect1><itemizedlist><listitem><para>
#: en/chapter03/introduction.xml:100
msgid ""
"The files can be downloaded using <command>wget</command> and a wget-list as "
"described below."
msgstr ""

#. type: Content of: <sect1><para>
#: en/chapter03/introduction.xml:105
msgid ""
"To download all of the packages and patches by using <ulink url=\"../&wget-"
"list;\">&wget-list;</ulink> as an input to the <command>wget</command> "
"command, use:"
msgstr ""

#. type: Content of: <sect1><screen>
#: en/chapter03/introduction.xml:109
#, no-wrap
msgid "<userinput>wget --input-file=&wget-list; --continue --directory-prefix=$LFS/sources</userinput>"
msgstr ""

#. type: Content of: <sect1><para>
#: en/chapter03/introduction.xml:119
msgid ""
"Additionally, starting with LFS-7.0, there is a separate file, <ulink "
"url=\"../md5sums\">md5sums</ulink>, which can be used to verify that all the "
"correct packages are available before proceeding.  Place that file in "
"<filename class=\"directory\">$LFS/sources</filename> and run:"
msgstr ""

#. type: Content of: <sect1><screen>
#: en/chapter03/introduction.xml:124
#, no-wrap
msgid ""
"<userinput>pushd $LFS/sources\n"
"  md5sum -c md5sums\n"
"popd</userinput>"
msgstr ""

#. type: Content of: <sect1><para>
#: en/chapter03/introduction.xml:128
msgid ""
"This check can be used after retrieving the needed files with any of the "
"methods listed above."
msgstr ""

#. type: Content of: <sect1><para>
#: en/chapter03/introduction.xml:131
msgid ""
"If the packages and patches are downloaded as a non-&root; user, these files "
"will be owned by the user.  The file system records the owner by its UID, "
"and the UID of a normal user in the host distro is not assigned in LFS.  So "
"the files will be left owned by an unnamed UID in the final LFS system.  If "
"you won't assign the same UID for your user in the LFS system, change the "
"owners of these files to &root; now to avoid this issue:"
msgstr ""

#. type: Content of: <sect1><screen>
#: en/chapter03/introduction.xml:139
#, no-wrap
msgid "<userinput>chown root:root $LFS/sources/*</userinput>"
msgstr ""

#. type: Content of the kernel-directory entity
#: en/chapter03/packages.xml:6
msgid "https://www.kernel.org/pub/linux/kernel/v6.x"
msgstr "https://www.kernel.org/pub/linux/kernel/v6.x"

