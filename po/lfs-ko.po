#: en/chapter08/libxcrypt.xml:70
msgid "<parameter>--enable-obsolete-api=no</parameter>"
msgstr "<parameter>--enable-obsolete-api=no</parameter>"

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><para>
#: en/chapter08/libxcrypt.xml:72
msgid ""
"Disable obsolete API functions.  They are not needed for a modern Linux "
"system built from source."
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><term>
#: en/chapter08/libxcrypt.xml:78
msgid "<parameter>--disable-failure-tokens</parameter>"
msgstr "<parameter>--disable-failure-tokens</parameter>"

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><para>
#: en/chapter08/libxcrypt.xml:80
msgid ""
"Disable failure token feature.  It's needed for compatibility with the "
"traditional hash libraries of some platforms, but a Linux system based on "
"Glibc does not need it."
msgstr ""

#. type: Content of: <sect1><sect2><note><para>
#: en/chapter08/libxcrypt.xml:102
msgid ""
"The instructions above disabled obsolete API functions since no package "
"installed by compiling from sources would link against them at runtime. "
"However, the only known binary-only applications that link against these "
"functions require ABI version 1.  If you must have such functions because of "
"some binary-only application or to be compliant with LSB, build the package "
"again with the following commands:"
msgstr ""

#. type: Content of: <sect1><sect2><note><screen>
#: en/chapter08/libxcrypt.xml:110
#, no-wrap
msgid ""
"<userinput>make distclean\n"
"./configure --prefix=/usr                \\\n"
"            --enable-hashes=strong,glibc \\\n"
"            --enable-obsolete-api=glibc  \\\n"
"            --disable-static             \\\n"
"            --disable-failure-tokens\n"
"make\n"
"cp -av --remove-destination .libs/libcrypt.so.1* /usr/lib</userinput>"
msgstr ""
"<userinput>make distclean\n"
"./configure --prefix=/usr                \\\n"
"            --enable-hashes=strong,glibc \\\n"
"            --enable-obsolete-api=glibc  \\\n"
"            --disable-static             \\\n"
"            --disable-failure-tokens\n"
"make\n"
"cp -av --remove-destination .libs/libcrypt.so.1* /usr/lib</userinput>"

