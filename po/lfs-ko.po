msgstr ""

#. type: Content of: <sect1><sect2><screen>
#: en/chapter08/bash.xml:74
#, no-wrap
msgid "<userinput remap=\"test\">chown -R tester .</userinput>"
msgstr ""

#. type: Content of: <sect1><sect2><para>
#: en/chapter08/bash.xml:76
msgid ""
"The test suite of this package is designed to be run as a non-&root; user "
"who owns the terminal connected to standard input.  To satisfy the "
"requirement, spawn a new pseudo terminal using <application>Expect</"
"application> and run the tests as the <systemitem class=\"username\">tester</"
"systemitem> user:"
msgstr ""

#. type: Content of: <sect1><sect2><screen>
#: en/chapter08/bash.xml:82
#, no-wrap
msgid ""
"<userinput remap=\"test\">LC_ALL=C.UTF-8 su -s /usr/bin/expect tester &lt;&lt; \"EOF\"\n"
"set timeout -1\n"
"spawn make tests\n"
"expect eof\n"
"lassign [wait] _ _ _ value\n"
"exit $value\n"
"EOF</userinput>"
msgstr ""

#.  Some host distros set core file size hard limit < 1000, then the
#.          test "ulimit -c -S 1000" attempts to set soft limit >
#.  hard limit
#.          and fail.  
#. type: Content of: <sect1><sect2><para>
#: en/chapter08/bash.xml:90
msgid ""
"The test suite uses <command>diff</command> to detect the difference between "
"test script output and the expected output.  Any output from <command>diff</"
"command> (prefixed with <computeroutput>&lt;</computeroutput> and "
"<computeroutput>&gt;</computeroutput>) indicates a test failure, unless "
"there is a message saying the difference can be ignored.  The test named "
"<filename>run-builtins</filename> is known to fail on some host distros with "
"a difference on the 479 and 480 lines of the output.  Some other tests need "
"the <literal>zh_TW.BIG5</literal> and <literal>ja_JP.SJIS</literal> locales, "
"they are known to fail unless those locales are installed."
msgstr ""

