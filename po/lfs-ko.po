#: en/chapter07/perl.xml:89
msgid "<parameter>-D privlib,-D archlib,-D sitelib,...</parameter>"
msgstr "<parameter>-D privlib,-D archlib,-D sitelib,...</parameter>"

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><para>
#: en/chapter07/perl.xml:91
msgid ""
"These settings define where Perl looks for installed modules. The LFS "
"editors chose to put them in a directory structure based on the MAJOR.MINOR "
"version of Perl (&perl-version-min;) which allows upgrading Perl to newer "
"patch levels (the patch level is the last dot separated part in the full "
"version string like &perl-version;) without reinstalling all of the modules."
