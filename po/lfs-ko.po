#: en/chapter08/groff.xml:54
#, no-wrap
msgid "<userinput remap=\"configure\">PAGE=<replaceable>&lt;paper_size&gt;</replaceable> ./configure --prefix=/usr</userinput>"
msgstr "<userinput remap=\"configure\">PAGE=<replaceable>&lt;paper_size&gt;</replaceable> ./configure --prefix=/usr</userinput>"

