#. type: Content of: <sect1><sect2><title>
#: en/chapter06/ncurses.xml:44 en/chapter08/ncurses.xml:42
msgid "Installation of Ncurses"
msgstr "Installation of Ncurses"

#. type: Content of: <sect1><sect2><para>
#: en/chapter06/ncurses.xml:46
msgid ""
"First, run the following commands to build the <command>tic</command> "
"program on the build host. We install it in <filename "
"class=\"directory\">$LFS/tools</filename>, so that it is found in the "
"<envar>PATH</envar> when needed:"
msgstr ""

#. type: Content of: <sect1><sect2><screen>
#: en/chapter06/ncurses.xml:51
#, no-wrap
msgid ""
"<userinput remap=\"pre\">mkdir build\n"
"pushd build\n"
"  ../configure --prefix=$LFS/tools AWK=gawk\n"
"  make -C include\n"
"  make -C progs tic\n"
"  install progs/tic $LFS/tools/bin\n"
"popd</userinput>"
msgstr ""

#. type: Content of: <sect1><sect2><para>
#: en/chapter06/ncurses.xml:59 en/chapter08/ncurses.xml:44
msgid "Prepare Ncurses for compilation:"
msgstr "Prepare Ncurses for compilation:"

#. type: Content of: <sect1><sect2><screen>
#: en/chapter06/ncurses.xml:61
#, no-wrap
msgid ""
"<userinput remap=\"configure\">./configure --prefix=/usr                \\\n"
"            --host=$LFS_TGT              \\\n"
"            --build=$(./config.guess)    \\\n"
"            --mandir=/usr/share/man      \\\n"
"            --with-manpage-format=normal \\\n"
"            --with-shared                \\\n"
"            --without-normal             \\\n"
"            --with-cxx-shared            \\\n"
"            --without-debug              \\\n"
"            --without-ada                \\\n"
"            --disable-stripping          \\\n"
"            AWK=gawk</userinput>"
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><term>
#: en/chapter06/ncurses.xml:78
msgid "<parameter>--with-manpage-format=normal</parameter>"
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><para>
#: en/chapter06/ncurses.xml:80
msgid ""
"This prevents Ncurses from installing compressed manual pages, which may "
"happen if the host distribution itself has compressed manual pages."
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><term>
#: en/chapter06/ncurses.xml:87 en/chapter08/ncurses.xml:60
msgid "<parameter>--with-shared</parameter>"
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><para>
#: en/chapter06/ncurses.xml:89 en/chapter08/ncurses.xml:62
msgid "This makes Ncurses build and install shared C libraries."
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><term>
#: en/chapter06/ncurses.xml:94 en/chapter08/ncurses.xml:67
msgid "<parameter>--without-normal</parameter>"
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><para>
#: en/chapter06/ncurses.xml:96
msgid "This prevents Ncurses from building and installing static C libraries."
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><term>
#: en/chapter06/ncurses.xml:102 en/chapter08/ncurses.xml:75
msgid "<parameter>--without-debug</parameter>"
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><para>
#: en/chapter06/ncurses.xml:104
msgid "This prevents Ncurses from building and installing debug libraries."
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><term>
#: en/chapter06/ncurses.xml:110 en/chapter08/ncurses.xml:83
msgid "<parameter>--with-cxx-shared</parameter>"
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><para>
#: en/chapter06/ncurses.xml:112 en/chapter08/ncurses.xml:85
msgid ""
"This makes Ncurses build and install shared C++ bindings. It also prevents "
"it building and installing static C++ bindings."
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><term>
#: en/chapter06/ncurses.xml:118
msgid "<parameter>--without-ada</parameter>"
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><para>
#: en/chapter06/ncurses.xml:120
msgid ""
"This ensures that Ncurses does not build support for the Ada compiler, which "
"may be present on the host but will not be available once we enter the "
"<command>chroot</command> environment."
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><term>
#: en/chapter06/ncurses.xml:127
msgid "<parameter>--disable-stripping</parameter>"
msgstr "<parameter>--disable-stripping</parameter>"

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><para>
#: en/chapter06/ncurses.xml:129
msgid ""
"This switch prevents the building system from using the <command>strip</"
"command> program from the host.  Using host tools on cross-compiled programs "
"can cause failure."
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><term>
#: en/chapter06/ncurses.xml:136
msgid "<parameter>AWK=gawk</parameter>"
msgstr ""

#.  FIXME vauge 
#.  It seems happened in 2015,
#.           is there any updated into? 
#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><para>
#: en/chapter06/ncurses.xml:138
msgid ""
"This switch prevents the building system from using the <command>mawk</"
"command> program from the host.  Some versions of <command>mawk</command> "
"can cause this package to fail to build."
msgstr ""

#. type: Content of: <sect1><sect2><screen>
#: en/chapter06/ncurses.xml:153
#, no-wrap
msgid ""
"<userinput remap=\"install\">make DESTDIR=$LFS install\n"
"ln -sv libncursesw.so $LFS/usr/lib/libncurses.so\n"
"sed -e 's/^#if.*XOPEN.*$/#if 1/' \\\n"
"    -i $LFS/usr/include/curses.h</userinput>"
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><title>
#: en/chapter06/ncurses.xml:159
msgid "The meaning of the install options:"
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><term>
#: en/chapter06/ncurses.xml:162
msgid "<command>ln -sv libncursesw.so $LFS/usr/lib/libncurses.so</command>"
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><para>
#: en/chapter06/ncurses.xml:164
msgid ""
"The <filename>libncurses.so</filename> library is needed by a few packages "
"we will build soon. We create this symlink to use <filename>libncursesw.so</"
"filename> as a replacement."
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><term>
#: en/chapter06/ncurses.xml:171
msgid "<command>sed -e 's/^#if.*XOPEN.*$/#if 1/' ...</command>"
msgstr "<command>sed -e 's/^#if.*XOPEN.*$/#if 1/' ...</command>"

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><para>
#: en/chapter06/ncurses.xml:173
msgid ""
"The header file <filename>curses.h</filename> contains the definition of "
"various Ncurses data structures.  With different preprocessor macro "
"definitions two different sets of the data structure definition may be used: "
"the 8-bit definition is compatible with <filename>libncurses.so</filename> "
"and the wide-character definition is compatible with "
"<filename>libncursesw.so</filename>.  Since we are using "
"<filename>libncursesw.so</filename> as a replacement of "
"<filename>libncurses.so</filename>, edit the header file so it will always "
"use the wide-character data structure definition compatible with "
"<filename>libncursesw.so</filename>."
msgstr ""

