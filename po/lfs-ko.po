#: en/chapter06/gcc-pass2.xml:12
msgid ""
"<productname>gcc-pass2</productname> <productnumber>&gcc-version;</"
"productnumber> <placeholder type=\"address\" id=\"0\"/>"
msgstr ""
"<productname>gcc-pass2</productname> <productnumber>&gcc-version;</"
"productnumber> <placeholder type=\"address\" id=\"0\"/>"

#. type: Content of: <sect1><title>
#: en/chapter06/gcc-pass2.xml:17
msgid "GCC-&gcc-version; - Pass 2"
msgstr "GCC-&gcc-version; - 패스 2"

#. type: Content of: <sect1><sect2><segmentedlist><seglistitem><seg>
#: en/chapter06/gcc-pass2.xml:36
msgid "&gcc-tmpp2-sbu;"
msgstr "&gcc-tmpp2-sbu;"

