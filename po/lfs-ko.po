msgstr "udev"

#. type: Content of: <sect1><sect2><variablelist><varlistentry><term>
#: en/chapter09/bootscripts.xml:316
msgid "<command>udev_retry</command>"
msgstr "<command>udev_retry</command>"

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><para>
#: en/chapter09/bootscripts.xml:318
msgid ""
"Retries failed udev uevents, and copies generated rules files from <filename "
"class=\"directory\">/run/udev</filename> to <filename class=\"directory\">/"
"etc/udev/rules.d</filename> if required"
msgstr ""
"실패한 udev uevent를 재시도하며, 필요한 경우 생성된 규칙 파일들을 <filename "
"class=\"directory\">/run/udev</filename> 디렉터리에서 <filename "
"class=\"directory\">/etc/udev/rules.d</filename> 디렉터리로 복사"

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><indexterm><primary>
#: en/chapter09/bootscripts.xml:322
