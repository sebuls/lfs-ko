msgstr "<parameter>--enable-fts{4,5}</parameter>"

#. type: Content of: <sect1><sect2><variablelist><varlistentry><listitem><para>
#: en/chapter08/sqlite.xml:64
msgid ""
"These switches enable support for version 4 and 5 of the full text search "
"(FTS) extension."
msgstr ""

#. type: Content of: <sect1><sect2><variablelist><varlistentry><term>
#: en/chapter08/sqlite.xml:70
msgid ""
"<parameter>CPPFLAGS=\"-D SQLITE_ENABLE_COLUMN_METADATA=1 ...</parameter>"
